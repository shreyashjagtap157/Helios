// Tutorial 02: Ownership Basics - Simplified
module tutorials::ownership

fn move_demo():
    let a = 42
    let b = a
    println("a = {}, b = {}", a, b)

fn borrow_demo():
    let mut x = 10
    println("x = {}", x)
    x = 20
    println("x = {}", x)

fn ownership_modes():
    let value = 100
    println("Value: {}", value)

fn main():
    println("=== Tutorial 02: Ownership ===")
    move_demo()
    borrow_demo()
    ownership_modes()
    println("Done")
