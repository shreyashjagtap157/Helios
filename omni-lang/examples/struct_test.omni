// Test struct support in the interpreter
module struct_test

struct Point:
    x: int
    y: int
    
    fn new(x: int, y: int) -> Point:
        return Point { x: x, y: y }
    
    fn distance_from_origin(&self) -> float:
        return float(self.x * self.x + self.y * self.y)
    
    fn translate(&self, dx: int, dy: int) -> Point:
        return Point { x: self.x + dx, y: self.y + dy }

fn main():
    println("=== Struct Tests ===")
    
    // Test struct literal
    let p = Point { x: 3, y: 4 }
    println("Point created")
    
    // Test field access
    println("p.x = " + format(p.x))
    println("p.y = " + format(p.y))
    
    // Test static method
    let p2 = Point::new(10, 20)
    println("p2.x = " + format(p2.x))
    
    println("=== Struct Tests Complete ===")
