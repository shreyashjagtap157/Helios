// Omni Language - Comprehensive Integration Test
// Tests: variables, arithmetic, strings, structs, recursion,
//        control flow, arrays, nested calls, type conversions
module integration_test

struct Vec2:
    x: float
    y: float
    fn new(x: float, y: float) -> Vec2:
        return Vec2 { x: x, y: y }
    fn add(&self, other: Vec2) -> Vec2:
        return Vec2 { x: self.x + other.x, y: self.y + other.y }
    fn scale(&self, f: float) -> Vec2:
        return Vec2 { x: self.x * f, y: self.y * f }

struct Stack:
    items: list
    size: int
    fn new() -> Stack:
        return Stack { items: [], size: 0 }
    fn push_val(&self, val: int) -> Stack:
        let new_items = self.items.push(val)
        return Stack { items: new_items, size: self.size + 1 }
    fn is_empty(&self) -> bool:
        return self.size == 0

fn fibonacci(n: int) -> int:
    if n <= 0:
        return 0
    if n == 1:
        return 1
    let a = 0
    let b = 1
    for i in range(2, n + 1):
        let temp = b
        b = a + b
        a = temp
    return b

fn factorial(n: int) -> int:
    if n <= 1:
        return 1
    return n * factorial(n - 1)

fn gcd(a: int, b: int) -> int:
    while b != 0:
        let temp = b
        b = a % b
        a = temp
    return a

fn power(base: int, exp: int) -> int:
    let result = 1
    for i in range(exp):
        result = result * base
    return result

fn abs_val(n: int) -> int:
    if n < 0:
        return 0 - n
    return n

fn clamp(val: int, lo: int, hi: int) -> int:
    if val < lo:
        return lo
    if val > hi:
        return hi
    return val

fn min_val(a: int, b: int) -> int:
    if a < b:
        return a
    return b

fn max_val(a: int, b: int) -> int:
    if a > b:
        return a
    return b

fn fizzbuzz(n: int) -> string:
    if n % 15 == 0:
        return "FizzBuzz"
    if n % 3 == 0:
        return "Fizz"
    if n % 5 == 0:
        return "Buzz"
    return format(n)

fn sum_array(arr: list) -> int:
    let total = 0
    for item in arr:
        total = total + item
    return total

fn test_arithmetic():
    println("-- 1. Variables and Arithmetic --")
    let x = 42
    let y = 13
    println("42 + 13 = " + format(x + y))
    println("42 - 13 = " + format(x - y))
    println("42 * 13 = " + format(x * y))
    println("42 / 13 = " + format(x / y))
    println("42 % 13 = " + format(x % y))
    let neg = 0 - 7
    println("negation = " + format(neg))
    if x + y == 55 and x * y == 546 and x % y == 3:
        println("[PASS] All arithmetic correct")
    else:
        println("[FAIL] Arithmetic error")

fn test_strings():
    println("-- 2. String Operations --")
    let full = "Hello" + ", " + "World" + "!"
    println("concat: " + full)
    println("length: " + format(len("Omni")))
    println("upper: " + "hello".upper())
    println("lower: " + "WORLD".lower())
    let has = "hello world".contains("world")
    println("contains: " + format(has))
    let rep = "foo bar foo".replace("foo", "baz")
    println("replace: " + rep)
    println("starts_with: " + format("Hello".starts_with("Hel")))
    let conv = format(42) + " is the answer"
    println("format: " + conv)
    if full == "Hello, World!" and "hello".upper() == "HELLO":
        println("[PASS] All string ops correct")
    else:
        println("[FAIL] String error")

fn test_structs():
    println("-- 3. Structs with Methods --")
    let v1 = Vec2 { x: 3.0, y: 4.0 }
    println("v1.x = " + format(v1.x))
    println("v1.y = " + format(v1.y))
    let v2 = Vec2::new(1.0, 2.0)
    println("v2 = (" + format(v2.x) + ", " + format(v2.y) + ")")
    let v3 = v1.add(v2)
    println("v1+v2 = (" + format(v3.x) + ", " + format(v3.y) + ")")
    let v4 = v1.scale(2.0)
    println("v1*2 = (" + format(v4.x) + ", " + format(v4.y) + ")")
    if v3.x == 4.0 and v3.y == 6.0 and v4.x == 6.0:
        println("[PASS] All struct ops correct")
    else:
        println("[FAIL] Struct error")
    let s = Stack::new()
    if s.is_empty():
        println("[PASS] Stack is_empty on new")
    else:
        println("[FAIL] Stack is_empty")
    let s2 = s.push_val(10)
    if s2.size == 1:
        println("[PASS] Stack push: size = " + format(s2.size))
    else:
        println("[FAIL] Stack push")

fn test_recursion():
    println("-- 4. Functions and Recursion --")
    println("fib(0) = " + format(fibonacci(0)))
    println("fib(1) = " + format(fibonacci(1)))
    println("fib(10) = " + format(fibonacci(10)))
    println("fact(5) = " + format(factorial(5)))
    println("fact(0) = " + format(factorial(0)))
    println("gcd(48,18) = " + format(gcd(48, 18)))
    println("2^10 = " + format(power(2, 10)))
    if fibonacci(10) == 55 and factorial(5) == 120 and gcd(48, 18) == 6 and power(2, 10) == 1024:
        println("[PASS] All recursion/functions correct")
    else:
        println("[FAIL] Recursion error")

fn test_control_flow():
    println("-- 5. Control Flow --")
    let val = 42
    let label = "unknown"
    if val > 100:
        label = "big"
    else:
        if val > 10:
            label = "medium"
        else:
            label = "small"
    println("classify 42: " + label)
    let sum = 0
    for i in range(1, 11):
        sum = sum + i
    println("sum(1..10) = " + format(sum))
    let count = 0
    let prod = 1
    while count < 5:
        count = count + 1
        prod = prod * count
    println("5! via while = " + format(prod))
    let pairs = 0
    for i in range(3):
        for j in range(4):
            pairs = pairs + 1
    println("3x4 nested = " + format(pairs))
    println("fizz(15) = " + fizzbuzz(15))
    println("fizz(9) = " + fizzbuzz(9))
    println("fizz(10) = " + fizzbuzz(10))
    println("fizz(7) = " + fizzbuzz(7))
    if label == "medium" and sum == 55 and prod == 120 and pairs == 12:
        println("[PASS] All control flow correct")
    else:
        println("[FAIL] Control flow error")

fn test_arrays():
    println("-- 6. Arrays and List Operations --")
    let arr = [10, 20, 30, 40, 50]
    println("len = " + format(len(arr)))
    println("sum = " + format(sum_array(arr)))
    let arr2 = arr.push(60)
    println("after push len = " + format(len(arr2)))
    let mx = 0
    for item in arr:
        if item > mx:
            mx = item
    println("max = " + format(mx))
    let squares = []
    for i in range(1, 6):
        squares = squares.push(i * i)
    println("squares len = " + format(len(squares)))
    println("sum squares = " + format(sum_array(squares)))
    if len(arr) == 5 and sum_array(arr) == 150 and mx == 50 and sum_array(squares) == 55:
        println("[PASS] All array ops correct")
    else:
        println("[FAIL] Array error")

fn test_nested_calls():
    println("-- 7. Nested Function Calls --")
    let n1 = max_val(min_val(100, 50), min_val(30, 70))
    println("max(min(100,50),min(30,70)) = " + format(n1))
    let n2 = abs_val(0 - max_val(3, 7))
    println("abs(-max(3,7)) = " + format(n2))
    let n3 = clamp(150, 0, 100)
    println("clamp(150,0,100) = " + format(n3))
    let n4 = clamp(0 - 5, 0, 100)
    println("clamp(-5,0,100) = " + format(n4))
    let n5 = fibonacci(factorial(3))
    println("fib(fact(3)) = fib(6) = " + format(n5))
    if n1 == 50 and n2 == 7 and n3 == 100 and n4 == 0 and n5 == 8:
        println("[PASS] All nested calls correct")
    else:
        println("[FAIL] Nested calls error")

fn test_types_and_logic():
    println("-- 8. Boolean Logic and Type Conversions --")
    let a = true
    let b = false
    println("true and !false = " + format(a and not b))
    println("!(true and false) = " + format(not (a and b)))
    println("true or false = " + format(a or b))
    let iv = int("123")
    println("int('123') = " + format(iv))
    let sv = format(456)
    println("format(456) = " + sv)
    let tn = type_of(42)
    println("type_of(42) = " + tn)
    let ts = type_of("hi")
    println("type_of('hi') = " + ts)
    if iv == 123 and sv == "456" and tn == "int" and ts == "string":
        println("[PASS] All type ops correct")
    else:
        println("[FAIL] Type ops error")

fn main():
    println("========================================")
    println("  Omni Comprehensive Integration Test")
    println("========================================")
    test_arithmetic()
    test_strings()
    test_structs()
    test_recursion()
    test_control_flow()
    test_arrays()
    test_nested_calls()
    test_types_and_logic()
    println("========================================")
    println("  ALL 8 SECTIONS COMPLETE")
    println("========================================")
