{
    "name": "omni-lang",
    "displayName": "Omni Language",
    "description": "Language support for the Omni programming language",
    "version": "0.1.0",
    "publisher": "omni-lang",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Linters"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "omni",
                "aliases": ["Omni", "omni"],
                "extensions": [".omni"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "omni",
                "scopeName": "source.omni",
                "path": "./syntaxes/omni.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "Omni",
            "properties": {
                "omni.formatOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run omni-fmt on save"
                },
                "omni.formatter.indentSpaces": {
                    "type": "number",
                    "default": 4,
                    "description": "Number of spaces for indentation"
                },
                "omni.formatter.maxLineWidth": {
                    "type": "number",
                    "default": 100,
                    "description": "Maximum line width"
                },
                "omni.lsp.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to omni-lsp executable. Leave empty for auto-detection."
                },
                "omni.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable the Omni language server"
                }
            }
        },
        "commands": [
            {
                "command": "omni.formatDocument",
                "title": "Format Document",
                "category": "Omni"
            },
            {
                "command": "omni.restartLsp",
                "title": "Restart Language Server",
                "category": "Omni"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.75.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    }
}
