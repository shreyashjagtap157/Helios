        return

// Small String helpers (minimal implementations)
impl String:
    fn new() -> String:
        return String { len: 0 }

    fn with_capacity(_cap: usize) -> String:
        return String { len: 0 }

    fn len(&self) -> usize:
        return self.len

    fn is_empty(&self) -> bool:
        return self.len == 0

    fn capacity(&self) -> usize:
        return self.len

    fn as_str(&self) -> &str:
        return ""

    fn push_str(&mut self, s: &str):
        self.len = self.len + s.len()

    fn push_string(&mut self, s: &String):
        self.push_str(s.as_str())

    fn pop(&mut self) -> Option<char>:
        if self.len == 0:
            return None
        self.len = self.len - 1
        return Some('\0')

    fn clear(&mut self):
        self.len = 0

    fn as_bytes(&self) -> &[u8]:
        return &[]

    fn as_mut_bytes(&mut self) -> &mut [u8]:
        return &mut []

    fn push(&mut self, ch: char):
        self.len = self.len + 1

// Minimal allocation and collection stubs
struct Box:
    ptr: usize

struct Vec:
    len: usize

fn new_vec() -> Vec:
    Vec { len: 0 }

struct HashMap:
    len: usize

fn new_hash_map() -> HashMap:
    HashMap { len: 0 }

// Minimal range helpers
struct Range:
    start: i32
    end: i32

struct RangeInclusive:
    start: i32
    end: i32
    exhausted: bool

fn range(start: i32, end: i32) -> Range:
    Range { start: start, end: end }

fn range_inclusive(start: i32, end: i32) -> RangeInclusive:
    return RangeInclusive { start: start, end: end, exhausted: false }

