module std::core

// Sanitized partial core (step 1) — safe, minimal subset for parser triage.
// Preserved original remains in ../preserved_full/core.omni

enum Option<T>:
    Some(T)
    None

impl Option<T>:
    fn is_some(&self) -> bool:
        match self:
            Some(_): true
            None: false

    fn is_none(&self) -> bool:
        return not self.is_some()

    fn unwrap(self) -> T:
        match self:
            Some(value): value
            None: panic("called unwrap() on None")

    fn unwrap_or(self, default: T) -> T:
        match self:
            Some(value): value
            None: default

    fn map<U>(self, f: fn(T) -> U) -> Option<U>:
        match self:
            Some(value): Some(f(value))
            None: None

    fn and_then<U>(self, f: fn(T) -> Option<U>) -> Option<U>:
        match self:
            Some(value): f(value)
            None: None

enum Result<T, E>:
    Ok(T)
    Err(E)

impl Result<T, E>:
    fn is_ok(&self) -> bool:
        match self:
            Ok(_): true
            Err(_): false

    fn is_err(&self) -> bool:
        return not self.is_ok()

    fn unwrap(self) -> T:
        match self:
            Ok(value): value
            Err(_): panic("called unwrap() on Err")

    fn unwrap_err(self) -> E:
        match self:
            Ok(_): panic("called unwrap_err() on Ok")
            Err(error): error

    fn unwrap_or(self, default: T) -> T:
        match self:
            Ok(value): value
            Err(_): default

    fn map<U>(self, f: fn(T) -> U) -> Result<U, E>:
        match self:
            Ok(value): Ok(f(value))
            Err(error): Err(error)

    fn map_err<F2>(self, f: fn(E) -> F2) -> Result<T, F2>:
        match self:
            Ok(value): Ok(value)
            Err(error): Err(f(error))

struct String:
    len: usize

fn panic(msg: &str):
    unreachable

// Add small Ordering enum as a next safe reintroduction step
enum Ordering:
    Less
    Equal
    Greater

// Minimal Iterator trait (no generics) to reintroduce common API surface
trait Iterator:
    type Item

    fn next(&mut self) -> Option<Self::Item>:
        return None

// Basic trait stubs (simplified) to reintroduce common APIs safely
trait Clone:
    fn clone(&self) -> Self:
        unreachable

trait Drop:
    fn drop(&mut self):
        unreachable

trait Default:
    fn default() -> Self:
        unreachable

trait Debug:
    fn fmt(&self) -> String:
        return "" 

trait Display:
    fn to_string(&self) -> String:
        return ""

trait PartialEq:
    fn eq(&self, other: &Self) -> bool:
        return false
    fn ne(&self, other: &Self) -> bool:
        return not self.eq(other)

trait Copy:
    pass

trait Eq:
    pass

trait PartialOrd:
    fn partial_cmp(&self, other: &Self) -> Option<Ordering>:
        return None
    fn lt(&self, other: &Self) -> bool:
        return self.partial_cmp(other) == Some(Ordering::Less)
    fn le(&self, other: &Self) -> bool:
        let c = self.partial_cmp(other)
        return c == Some(Ordering::Less) or c == Some(Ordering::Equal)
    fn gt(&self, other: &Self) -> bool:
        return self.partial_cmp(other) == Some(Ordering::Greater)
    fn ge(&self, other: &Self) -> bool:
        let c = self.partial_cmp(other)
        return c == Some(Ordering::Greater) or c == Some(Ordering::Equal)

trait Ord:
    fn cmp(&self, other: &Self) -> Ordering:
        return Ordering::Equal

