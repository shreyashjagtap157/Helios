module std::math

// Minimal math stubs for Stage0 bootstrap.

fn pi() -> f64:
    return 3.141592653589793

fn e() -> f64:
    return 2.718281828459045

fn sin(x: f64) -> f64:
    return 0.0

fn cos(x: f64) -> f64:
    return 1.0

fn tan(x: f64) -> f64:
    return 0.0

fn powf(x: f64, y: f64) -> f64:
    return 1.0

fn abs_i64(x: i64) -> i64:
    if x < 0:
        return -x
    return x
