module tests::parser

// ============================================================================
// Parser Tests — Comprehensive test suite for the parser
// ============================================================================

import compiler::parser::ast::*
import compiler::parser::mod::{Parser, parse}
import compiler::lexer::mod::{tokenize}
import std::core::{String, Vector, Option, Some, None, assert, assert_eq}

// ============================================================================
// Expression Parsing
// ============================================================================

#[test]
fn test_parse_integer():
    let ast = parse_expr("42")
    assert(is_int_literal(&ast, 42), "should parse integer literal")

#[test]
fn test_parse_float():
    let ast = parse_expr("3.14")
    assert(is_float_literal(&ast), "should parse float literal")

#[test]
fn test_parse_string():
    let ast = parse_expr("\"hello\"")
    assert(is_string_literal(&ast), "should parse string literal")

#[test]
fn test_parse_bool_true():
    let ast = parse_expr("true")
    assert(is_bool_literal(&ast, true), "should parse true")

#[test]
fn test_parse_bool_false():
    let ast = parse_expr("false")
    assert(is_bool_literal(&ast, false), "should parse false")

#[test]
fn test_parse_identifier():
    let ast = parse_expr("foo")
    assert(is_identifier(&ast, "foo"), "should parse identifier")

// ============================================================================
// Binary Expression Tests
// ============================================================================

#[test]
fn test_parse_addition():
    let ast = parse_expr("1 + 2")
    match ast:
        Expr::Binary(lhs, op, rhs) =>
            assert(is_int_literal(lhs, 1), "lhs should be 1")
            assert(op == BinOp::Add, "op should be Add")
            assert(is_int_literal(rhs, 2), "rhs should be 2")
        _ => assert(false, "should be binary expr")

#[test]
fn test_precedence_mul_over_add():
    // 1 + 2 * 3 should parse as 1 + (2 * 3)
    let ast = parse_expr("1 + 2 * 3")
    match ast:
        Expr::Binary(lhs, op, rhs) =>
            assert(op == BinOp::Add, "top-level op should be Add")
            assert(is_int_literal(lhs, 1), "lhs should be 1")
            match rhs:
                Expr::Binary(_, inner_op, _) =>
                    assert(inner_op == BinOp::Mul, "inner op should be Mul")
                _ => assert(false, "rhs should be binary")
        _ => assert(false, "should be binary expr")

#[test]
fn test_comparison():
    let ast = parse_expr("a < b")
    match ast:
        Expr::Binary(_, op, _) =>
            assert(op == BinOp::Lt, "op should be Lt")
        _ => assert(false, "should be binary")

#[test]
fn test_logical_and():
    let ast = parse_expr("a && b")
    match ast:
        Expr::Binary(_, op, _) =>
            assert(op == BinOp::And, "op should be And")
        _ => assert(false, "should be binary")

#[test]
fn test_logical_or():
    let ast = parse_expr("a || b")
    match ast:
        Expr::Binary(_, op, _) =>
            assert(op == BinOp::Or, "op should be Or")
        _ => assert(false, "should be binary")

// ============================================================================
// Unary Expression Tests
// ============================================================================

#[test]
fn test_parse_negation():
    let ast = parse_expr("-x")
    match ast:
        Expr::Unary(op, _) =>
            assert(op == UnaryOp::Neg, "op should be Neg")
        _ => assert(false, "should be unary")

#[test]
fn test_parse_not():
    let ast = parse_expr("not x")
    match ast:
        Expr::Unary(op, _) =>
            assert(op == UnaryOp::Not, "op should be Not")
        _ => assert(false, "should be unary")

#[test]
fn test_parse_reference():
    let ast = parse_expr("&x")
    match ast:
        Expr::Unary(op, _) =>
            assert(op == UnaryOp::Ref, "op should be Ref")
        _ => assert(false, "should be unary ref")

#[test]
fn test_parse_deref():
    let ast = parse_expr("*x")
    match ast:
        Expr::Unary(op, _) =>
            assert(op == UnaryOp::Deref, "op should be Deref")
        _ => assert(false, "should be unary deref")

// ============================================================================
// Call Expression Tests
// ============================================================================

#[test]
fn test_function_call():
    let ast = parse_expr("foo(1, 2, 3)")
    match ast:
        Expr::Call(callee, args) =>
            assert(is_identifier(callee, "foo"), "callee should be foo")
            assert(args.len() == 3, "should have 3 args")
        _ => assert(false, "should be call expr")

#[test]
fn test_method_call():
    let ast = parse_expr("obj.method(x)")
    match ast:
        Expr::MethodCall(receiver, name, args) =>
            assert(name == "method", "method name")
            assert(args.len() == 1, "should have 1 arg")
        _ => assert(false, "should be method call")

#[test]
fn test_field_access():
    let ast = parse_expr("point.x")
    match ast:
        Expr::Field(_, name) =>
            assert(name == "x", "field should be x")
        _ => assert(false, "should be field access")

#[test]
fn test_index():
    let ast = parse_expr("arr[0]")
    match ast:
        Expr::Index(_, _) => pass  // Success
        _ => assert(false, "should be index expr")

// ============================================================================
// Statement Tests
// ============================================================================

#[test]
fn test_let_statement():
    let ast = parse_stmt("let x = 5")
    match ast:
        Stmt::Let(name, ty, init, is_mut) =>
            assert(name == "x", "name should be x")
            assert(not is_mut, "should not be mutable")
            assert(init.is_some(), "should have initializer")
        _ => assert(false, "should be let stmt")

#[test]
fn test_let_mut():
    let ast = parse_stmt("let mut x = 5")
    match ast:
        Stmt::Let(name, _, _, is_mut) =>
            assert(name == "x", "name should be x")
            assert(is_mut, "should be mutable")
        _ => assert(false, "should be let mut stmt")

#[test]
fn test_let_with_type():
    let ast = parse_stmt("let x: i32 = 5")
    match ast:
        Stmt::Let(name, ty, _, _) =>
            assert(name == "x", "name should be x")
            assert(ty.is_some(), "should have type annotation")
        _ => assert(false, "should be let stmt with type")

#[test]
fn test_return_stmt():
    let ast = parse_stmt("return 42")
    match ast:
        Stmt::Return(expr) =>
            assert(expr.is_some(), "should have return value")
        _ => assert(false, "should be return stmt")

#[test]
fn test_return_void():
    let ast = parse_stmt("return")
    match ast:
        Stmt::Return(expr) =>
            assert(expr.is_none(), "should not have return value")
        _ => assert(false, "should be return stmt")

// ============================================================================
// Control Flow Tests
// ============================================================================

#[test]
fn test_if_statement():
    let source = "if x > 0:\n    return x\n"
    let ast = parse_stmt(source)
    match ast:
        Stmt::If(cond, then_block, else_block) =>
            assert(else_block.is_none(), "should not have else")
        _ => assert(false, "should be if stmt")

#[test]
fn test_if_else():
    let source = "if x > 0:\n    return x\nelse:\n    return -x\n"
    let ast = parse_stmt(source)
    match ast:
        Stmt::If(cond, then_block, else_block) =>
            assert(else_block.is_some(), "should have else")
        _ => assert(false, "should be if-else stmt")

#[test]
fn test_while_loop():
    let source = "while x > 0:\n    x -= 1\n"
    let ast = parse_stmt(source)
    match ast:
        Stmt::While(_, _) => pass
        _ => assert(false, "should be while stmt")

#[test]
fn test_for_loop():
    let source = "for i in 0..10:\n    sum += i\n"
    let ast = parse_stmt(source)
    match ast:
        Stmt::For(var, iter, _) =>
            assert(var == "i", "loop var should be i")
        _ => assert(false, "should be for stmt")

#[test]
fn test_match_stmt():
    let source = "match x:\n    1 => \"one\"\n    2 => \"two\"\n    _ => \"other\"\n"
    let ast = parse_stmt(source)
    match ast:
        Stmt::Match(_, arms) =>
            assert(arms.len() == 3, "should have 3 arms")
        _ => assert(false, "should be match stmt")

// ============================================================================
// Item Declaration Tests
// ============================================================================

#[test]
fn test_function_decl():
    let source = "fn add(a: i32, b: i32) -> i32:\n    return a + b\n"
    let items = parse_module(source)
    assert(items.len() == 1, "should have 1 item")
    match items[0]:
        Item::Function(func) =>
            assert(func.name == "add", "name should be add")
            assert(func.params.len() == 2, "should have 2 params")
            assert(func.return_type.is_some(), "should have return type")
        _ => assert(false, "should be function")

#[test]
fn test_generic_function():
    let source = "fn identity<T>(x: T) -> T:\n    return x\n"
    let items = parse_module(source)
    match items[0]:
        Item::Function(func) =>
            assert(func.name == "identity", "name")
            assert(func.generics.len() == 1, "should have 1 generic param")
        _ => assert(false, "should be function")

#[test]
fn test_struct_decl():
    let source = "struct Point:\n    x: f64\n    y: f64\n"
    let items = parse_module(source)
    match items[0]:
        Item::Struct(s) =>
            assert(s.name == "Point", "name should be Point")
            assert(s.fields.len() == 2, "should have 2 fields")
        _ => assert(false, "should be struct")

#[test]
fn test_generic_struct():
    let source = "struct Pair<A, B>:\n    first: A\n    second: B\n"
    let items = parse_module(source)
    match items[0]:
        Item::Struct(s) =>
            assert(s.name == "Pair", "name")
            assert(s.generics.len() == 2, "should have 2 generics")
        _ => assert(false, "should be struct")

#[test]
fn test_enum_decl():
    let source = "enum Color:\n    Red\n    Green\n    Blue\n    Custom(u8, u8, u8)\n"
    let items = parse_module(source)
    match items[0]:
        Item::Enum(e) =>
            assert(e.name == "Color", "name should be Color")
            assert(e.variants.len() == 4, "should have 4 variants")
        _ => assert(false, "should be enum")

#[test]
fn test_trait_decl():
    let source = "trait Display:\n    fn fmt(&self, f: &mut Formatter) -> Result<(), Error>\n"
    let items = parse_module(source)
    match items[0]:
        Item::Trait(t) =>
            assert(t.name == "Display", "name should be Display")
            assert(t.methods.len() == 1, "should have 1 method")
        _ => assert(false, "should be trait")

#[test]
fn test_impl_block():
    let source = "impl Point:\n    fn new(x: f64, y: f64) -> own Point:\n        return Point { x: x, y: y }\n\n    fn distance(&self, other: &Point) -> f64:\n        let dx = self.x - other.x\n        let dy = self.y - other.y\n        return (dx * dx + dy * dy).sqrt()\n"
    let items = parse_module(source)
    match items[0]:
        Item::Impl(imp) =>
            assert(imp.type_name == "Point", "type should be Point")
            assert(imp.methods.len() == 2, "should have 2 methods")
            assert(imp.trait_name.is_none(), "should not be trait impl")
        _ => assert(false, "should be impl")

#[test]
fn test_trait_impl():
    let source = "impl Display for Point:\n    fn fmt(&self, f: &mut Formatter) -> Result<(), Error>:\n        write!(f, \"({}, {})\", self.x, self.y)\n"
    let items = parse_module(source)
    match items[0]:
        Item::Impl(imp) =>
            assert(imp.type_name == "Point", "type should be Point")
            assert(imp.trait_name == Some(String::from("Display")), "trait should be Display")
        _ => assert(false, "should be trait impl")

#[test]
fn test_import():
    let source = "import std::collections::{Vector, HashMap}\n"
    let items = parse_module(source)
    match items[0]:
        Item::Import(path, names) =>
            assert(path == "std::collections", "path")
            assert(names.len() == 2, "should import 2 names")
        _ => assert(false, "should be import")

#[test]
fn test_module_decl():
    let source = "module my_module\n"
    let items = parse_module(source)
    match items[0]:
        Item::Module(name) =>
            assert(name == "my_module", "module name")
        _ => assert(false, "should be module decl")

// ============================================================================
// Type Annotation Tests
// ============================================================================

#[test]
fn test_primitive_types():
    let ast = parse_type("i32")
    assert(is_type_name(&ast, "i32"), "should be i32")

#[test]
fn test_generic_type():
    let ast = parse_type("Vector<i32>")
    match ast:
        TypeExpr::Generic(name, args) =>
            assert(name == "Vector", "name should be Vector")
            assert(args.len() == 1, "should have 1 arg")
        _ => assert(false, "should be generic type")

#[test]
fn test_reference_type():
    let ast = parse_type("&str")
    match ast:
        TypeExpr::Ref(inner, is_mut) =>
            assert(not is_mut, "should not be mut ref")
        _ => assert(false, "should be ref type")

#[test]
fn test_mut_reference_type():
    let ast = parse_type("&mut i32")
    match ast:
        TypeExpr::Ref(_, is_mut) =>
            assert(is_mut, "should be mut ref")
        _ => assert(false, "should be mut ref type")

#[test]
fn test_option_type():
    let ast = parse_type("Option<String>")
    match ast:
        TypeExpr::Generic(name, args) =>
            assert(name == "Option", "name should be Option")
        _ => assert(false, "should be generic type")

#[test]
fn test_result_type():
    let ast = parse_type("Result<i32, String>")
    match ast:
        TypeExpr::Generic(name, args) =>
            assert(name == "Result", "name should be Result")
            assert(args.len() == 2, "should have 2 args")
        _ => assert(false, "should be generic type")

#[test]
fn test_array_type():
    let ast = parse_type("[i32; 10]")
    match ast:
        TypeExpr::Array(elem, size) =>
            assert(size == 10, "array size should be 10")
        _ => assert(false, "should be array type")

#[test]
fn test_tuple_type():
    let ast = parse_type("(i32, String, f64)")
    match ast:
        TypeExpr::Tuple(elements) =>
            assert(elements.len() == 3, "should have 3 elements")
        _ => assert(false, "should be tuple type")

// ============================================================================
// Complex Parsing Tests
// ============================================================================

#[test]
fn test_closure():
    let ast = parse_expr("|x, y| x + y")
    match ast:
        Expr::Closure(params, _, body) =>
            assert(params.len() == 2, "should have 2 params")
        _ => assert(false, "should be closure")

#[test]
fn test_if_expression():
    let ast = parse_expr("if cond: a else: b")
    match ast:
        Expr::If(_, _, else_branch) =>
            assert(else_branch.is_some(), "should have else branch")
        _ => assert(false, "should be if expr")

#[test]
fn test_struct_literal():
    let ast = parse_expr("Point { x: 1.0, y: 2.0 }")
    match ast:
        Expr::StructLit(name, fields) =>
            assert(name == "Point", "struct name")
            assert(fields.len() == 2, "should have 2 fields")
        _ => assert(false, "should be struct literal")

#[test]
fn test_array_literal():
    let ast = parse_expr("[1, 2, 3, 4, 5]")
    match ast:
        Expr::ArrayLit(elements) =>
            assert(elements.len() == 5, "should have 5 elements")
        _ => assert(false, "should be array literal")

#[test]
fn test_range_expr():
    let ast = parse_expr("0..10")
    match ast:
        Expr::Range(start, end, inclusive) =>
            assert(not inclusive, "should not be inclusive")
        _ => assert(false, "should be range expr")

#[test]
fn test_chained_method_calls():
    let ast = parse_expr("vec.iter().map(|x| x * 2).collect()")
    match ast:
        Expr::MethodCall(_, name, _) =>
            assert(name == "collect", "last method should be collect")
        _ => assert(false, "should be method call chain")

// ============================================================================
// Error Recovery Tests
// ============================================================================

#[test]
fn test_missing_semicolon():
    // Parser should still produce partial AST
    let items = parse_module("let x = 5\nlet y = 10\n")
    assert(items.len() > 0, "should produce some items despite missing structure")

#[test]
fn test_unbalanced_parens():
    let result = try_parse_expr("(1 + 2")
    assert(result.is_err(), "should produce error for unbalanced parens")

// ============================================================================
// Helper Functions
// ============================================================================

fn parse_expr(source: &str) -> Expr:
    let tokens = tokenize(source)
    let mut parser = Parser::new(tokens)
    return parser.parse_expression()

fn try_parse_expr(source: &str) -> Result<Expr, String>:
    let tokens = tokenize(source)
    let mut parser = Parser::new(tokens)
    return parser.try_parse_expression()

fn parse_stmt(source: &str) -> Stmt:
    let tokens = tokenize(source)
    let mut parser = Parser::new(tokens)
    return parser.parse_statement()

fn parse_module(source: &str) -> Vector<Item>:
    let tokens = tokenize(source)
    let mut parser = Parser::new(tokens)
    return parser.parse_module()

fn parse_type(source: &str) -> TypeExpr:
    let tokens = tokenize(source)
    let mut parser = Parser::new(tokens)
    return parser.parse_type()

fn is_int_literal(expr: &Expr, value: i64) -> bool:
    match expr:
        Expr::IntLit(v) => v == value
        _ => false

fn is_float_literal(expr: &Expr) -> bool:
    match expr:
        Expr::FloatLit(_) => true
        _ => false

fn is_string_literal(expr: &Expr) -> bool:
    match expr:
        Expr::StringLit(_) => true
        _ => false

fn is_bool_literal(expr: &Expr, value: bool) -> bool:
    match expr:
        Expr::BoolLit(v) => v == value
        _ => false

fn is_identifier(expr: &Expr, name: &str) -> bool:
    match expr:
        Expr::Ident(n) => n == name
        _ => false

fn is_type_name(ty: &TypeExpr, name: &str) -> bool:
    match ty:
        TypeExpr::Named(n) => n == name
        _ => false
