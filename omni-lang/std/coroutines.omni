// ============================================================================
// Coroutine Cancellation
// ============================================================================

struct CancellationToken:
    is_cancelled: bool

impl CancellationToken:
    fn new() -> own Self:
        return CancellationToken {
            is_cancelled: false,
        }
    
    fn cancel(&mut self):
        self.is_cancelled = true
    
    fn is_cancelled(&self) -> bool:
        self.is_cancelled
    
    fn check_cancelled(&self) -> Result<(), CancellationError>:
        if self.is_cancelled:
            Err(CancellationError::new())
        else:
            Ok(())

struct CancellationError:
    pass

impl CancellationError:
    fn new() -> own Self:
        return CancellationError {}

// ============================================================================
// Coroutine Scoping with Structured Concurrency
// ============================================================================

// Every coroutine runs within a scope:
// - Child coroutines inherit cancellation from parent
// - When scope exits, all child coroutines are cancelled
//
// Example:
//
// scope {
//     let task1 = spawn_task(|| { ... })
//     let task2 = spawn_task(|| { ... })
//     // When scope exits, both tasks are cancelled if not complete
// }

struct CoroutineScope:
    children: Vec<CancellationToken>
    cancelled: bool

impl CoroutineScope:
    fn new() -> own Self:
        return CoroutineScope {
            children: Vec::new(),
            cancelled: false,
        }
    
    fn spawn_child(&mut self) -> own CancellationToken:
        let token = CancellationToken::new()
        self.children.push(token.clone())
        return token
    
    fn cancel_all(&mut self):
        self.cancelled = true
        for child in &mut self.children:
            child.cancel()

// ============================================================================
// Coroutine Timing & Deadlines
// ============================================================================

struct Deadline:
    timeout_nanos: u64
    start_time: u64

impl Deadline:
    fn new(timeout_ms: u64) -> own Self:
        return Deadline {
            timeout_nanos: timeout_ms * 1_000_000,
            start_time: time::now_nanos(),
        }
    
    fn is_exceeded(&self) -> bool:
        let elapsed = time::now_nanos() - self.start_time
        elapsed >= self.timeout_nanos
    
    fn remaining_nanos(&self) -> u64:
        let elapsed = time::now_nanos() - self.start_time
        if elapsed >= self.timeout_nanos:
            0
        else:
            self.timeout_nanos - elapsed

// ============================================================================
// Coroutine Composition
// ============================================================================

// Sequence: Run coroutines one after another
fn sequence<Y, R>(
    first: Box<dyn Coroutine<Yield=Y, Return=R>>,
    second: Box<dyn Coroutine<Yield=Y, Return=R>>,
) -> Box<dyn Coroutine<Yield=Y, Return=R>>:
    // Return a new coroutine that runs first, then second
    // (requires compiler support for trait objects with generators)
    Box::new(SimpleCoroutine {
        inner: Box::new(|| {
            CoroutineState::Complete(())
        }),
    })

// Select: Resume first coroutine that yields
fn select<Y, R>(
    first: Box<dyn Coroutine<Yield=Y, Return=R>>,
    second: Box<dyn Coroutine<Yield=Y, Return=R>>,
) -> Box<dyn Coroutine<Yield=Y, Return=(usize, Y)>>:
    // Return a new coroutine that races both
    // Returns (index, yielded_value) for whichever completes first
    Box::new(SimpleCoroutine {
        inner: Box::new(|| {
            CoroutineState::Complete((0, todo!()))
        }),
    })

// ============================================================================
// Coroutine Performance Monitoring
// ============================================================================

struct CoroutineMetrics:
    total_yields: u64
    total_resumptions: u64
    time_in_coroutine_nanos: u64
    max_yield_time_nanos: u64

impl CoroutineMetrics:
    fn new() -> own Self:
        return CoroutineMetrics {
            total_yields: 0,
            total_resumptions: 0,
            time_in_coroutine_nanos: 0,
            max_yield_time_nanos: 0,
        }
    
    fn record_yield(&mut self, duration_nanos: u64):
        self.total_yields += 1
        self.time_in_coroutine_nanos += duration_nanos
        if duration_nanos > self.max_yield_time_nanos:
            self.max_yield_time_nanos = duration_nanos
    
    fn record_resumption(&mut self):
        self.total_resumptions += 1
    
    fn average_yield_time_nanos(&self) -> u64:
        if self.total_yields == 0:
            0
        else:
            self.time_in_coroutine_nanos / self.total_yields
