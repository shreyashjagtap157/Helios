# HELIOS Query Processing Engine
# Natural language understanding through pattern matching and semantic parsing
# Not LLM-based - uses structured linguistic analysis

module brain::query_processing

import core::logging as log
import core::collections
import brain::knowledge_graph as kg
import brain::reasoning_engine as re
import brain::memory_architecture as mem

# ============================================================================
# QUERY PARSER
# ============================================================================

# Parse natural language into structured queries
struct QueryParser:
    # Pattern libraries
    question_patterns: Vec<QuestionPattern>
    command_patterns: Vec<CommandPattern>
    entity_recognizer: EntityRecognizer
    intent_classifier: IntentClassifier
    
    fn new() -> own QueryParser:
        return QueryParser {
            question_patterns: Self::default_question_patterns(),
            command_patterns: Self::default_command_patterns(),
            entity_recognizer: EntityRecognizer::new(),
            intent_classifier: IntentClassifier::new()
        }
    
    # Parse a natural language query
    fn parse(&self, input: &str) -> ParsedQuery:
        log::debug("Parsing query: {}", input)
        
        # Step 1: Normalize input
        let normalized = self.normalize(input)
        
        # Step 2: Classify intent
        let intent = self.intent_classifier.classify(&normalized)
        
        # Step 3: Extract entities
        let entities = self.entity_recognizer.extract(&normalized)
        
        # Step 4: Match patterns
        let structure = self.match_patterns(&normalized, &intent)
        
        # Step 5: Build parsed query
        return ParsedQuery {
            original: input.to_string(),
            normalized,
            intent,
            entities,
            structure,
            confidence: self.compute_confidence(&intent, &entities, &structure)
        }
    
    fn normalize(&self, input: &str) -> String:
        input.trim()
            .to_lowercase()
            # Remove extra whitespace
            .split_whitespace()
            .collect::<Vec<_>>()
            .join(" ")
    
    fn match_patterns(&self, input: &str, intent: &Intent) -> QueryStructure:
        match intent:
            Intent::Question(q_type) => {
                for pattern in &self.question_patterns:
                    if let Some(matched) = pattern.try_match(input):
                        return QueryStructure::Question {
                            question_type: q_type.clone(),
                            subject: matched.subject,
                            predicate: matched.predicate,
                            object: matched.object,
                            modifiers: matched.modifiers
                        }
                
                # Fallback to simple question
                return QueryStructure::Question {
                    question_type: q_type.clone(),
                    subject: None,
                    predicate: None,
                    object: None,
                    modifiers: Vec::new()
                }
            }
            
            Intent::Command(c_type) => {
                for pattern in &self.command_patterns:
                    if let Some(matched) = pattern.try_match(input):
                        return QueryStructure::Command {
                            command_type: c_type.clone(),
                            target: matched.target,
                            parameters: matched.parameters
                        }
                
                return QueryStructure::Command {
                    command_type: c_type.clone(),
                    target: None,
                    parameters: Map::new()
                }
            }
            
            Intent::Statement => {
                return QueryStructure::Statement {
                    subject: self.extract_subject(input),
                    predicate: self.extract_predicate(input),
                    object: self.extract_object(input)
                }
            }
            
            Intent::Greeting | Intent::Farewell | Intent::Unknown => {
                return QueryStructure::Simple(input.to_string())
            }
    
    fn extract_subject(&self, input: &str) -> Option<String>:
        # Find the subject (typically before the main verb)
        let words: Vec<&str> = input.split_whitespace().collect()
        if words.len() > 0:
            Some(words[0].to_string())
        else:
            None
    
    fn extract_predicate(&self, input: &str) -> Option<String>:
        # Find the main verb
        let verbs = ["is", "are", "was", "were", "has", "have", "do", "does", 
                     "can", "will", "would", "should", "could", "may", "might"]
        for word in input.split_whitespace():
            if verbs.contains(&word):
                return Some(word.to_string())
        None
    
    fn extract_object(&self, input: &str) -> Option<String>:
        # Find the object (after the verb)
        let verbs = ["is", "are", "was", "were", "has", "have"]
        let words: Vec<&str> = input.split_whitespace().collect()
        for (i, word) in words.iter().enumerate():
            if verbs.contains(word) && i + 1 < words.len():
                return Some(words[i + 1..].join(" "))
        None
    
    fn compute_confidence(&self, intent: &Intent, entities: &[Entity], 
                          structure: &QueryStructure) -> f64:
        let mut score = 0.0
        
        # Intent confidence
        score += match intent:
            Intent::Unknown => 0.2,
            _ => 0.4
        
        # Entity confidence
        if !entities.is_empty():
            score += 0.3
        
        # Structure confidence
        match structure:
            QueryStructure::Simple(_) => score += 0.1,
            _ => score += 0.3
        
        score.min(1.0)
    
    fn default_question_patterns() -> Vec<QuestionPattern>:
        vec![
            QuestionPattern::new("what is (.+)", QuestionType::Definition),
            QuestionPattern::new("what are (.+)", QuestionType::Definition),
            QuestionPattern::new("who is (.+)", QuestionType::Identity),
            QuestionPattern::new("who was (.+)", QuestionType::Identity),
            QuestionPattern::new("where is (.+)", QuestionType::Location),
            QuestionPattern::new("when did (.+)", QuestionType::Temporal),
            QuestionPattern::new("when was (.+)", QuestionType::Temporal),
            QuestionPattern::new("why (.+)", QuestionType::Reason),
            QuestionPattern::new("how (.+)", QuestionType::Method),
            QuestionPattern::new("how many (.+)", QuestionType::Quantity),
            QuestionPattern::new("how much (.+)", QuestionType::Quantity),
            QuestionPattern::new("is (.+) (.+)", QuestionType::YesNo),
            QuestionPattern::new("are (.+) (.+)", QuestionType::YesNo),
            QuestionPattern::new("can (.+)", QuestionType::Capability),
            QuestionPattern::new("does (.+)", QuestionType::YesNo),
            QuestionPattern::new("do (.+)", QuestionType::YesNo),
        ]
    
    fn default_command_patterns() -> Vec<CommandPattern>:
        vec![
            CommandPattern::new("remember (.+)", CommandType::Remember),
            CommandPattern::new("forget (.+)", CommandType::Forget),
            CommandPattern::new("learn (.+)", CommandType::Learn),
            CommandPattern::new("explain (.+)", CommandType::Explain),
            CommandPattern::new("summarize (.+)", CommandType::Summarize),
            CommandPattern::new("compare (.+) and (.+)", CommandType::Compare),
            CommandPattern::new("list (.+)", CommandType::List),
            CommandPattern::new("show (.+)", CommandType::Show),
            CommandPattern::new("search (.+)", CommandType::Search),
            CommandPattern::new("find (.+)", CommandType::Search),
            CommandPattern::new("help", CommandType::Help),
        ]

# ============================================================================
# INTENT CLASSIFICATION
# ============================================================================

struct IntentClassifier:
    question_starters: Vec<&'static str>
    command_verbs: Vec<&'static str>
    greetings: Vec<&'static str>
    farewells: Vec<&'static str>
    
    fn new() -> own IntentClassifier:
        return IntentClassifier {
            question_starters: vec![
                "what", "who", "where", "when", "why", "how", "which",
                "is", "are", "was", "were", "do", "does", "did", "can",
                "could", "would", "should", "will"
            ],
            command_verbs: vec![
                "remember", "forget", "learn", "explain", "tell", "show",
                "find", "search", "list", "get", "give", "help", "define",
                "describe", "calculate", "compare", "summarize", "create"
            ],
            greetings: vec![
                "hello", "hi", "hey", "good morning", "good afternoon",
                "good evening", "greetings"
            ],
            farewells: vec![
                "bye", "goodbye", "see you", "farewell", "good night"
            ]
        }
    
    fn classify(&self, input: &str) -> Intent:
        let first_word = input.split_whitespace().next().unwrap_or("")
        
        # Check for greetings
        for greeting in &self.greetings:
            if input.starts_with(greeting):
                return Intent::Greeting
        
        # Check for farewells
        for farewell in &self.farewells:
            if input.starts_with(farewell):
                return Intent::Farewell
        
        # Check for questions
        if input.ends_with("?") || self.question_starters.contains(&first_word):
            let q_type = self.classify_question_type(input)
            return Intent::Question(q_type)
        
        # Check for commands
        for verb in &self.command_verbs:
            if input.starts_with(verb):
                let c_type = self.classify_command_type(input)
                return Intent::Command(c_type)
        
        # Default to statement
        return Intent::Statement
    
    fn classify_question_type(&self, input: &str) -> QuestionType:
        let first_word = input.split_whitespace().next().unwrap_or("")
        
        match first_word:
            "what" => QuestionType::Definition,
            "who" => QuestionType::Identity,
            "where" => QuestionType::Location,
            "when" => QuestionType::Temporal,
            "why" => QuestionType::Reason,
            "how" => {
                if input.contains("many") || input.contains("much"):
                    QuestionType::Quantity
                else:
                    QuestionType::Method
            }
            "which" => QuestionType::Selection,
            "is" | "are" | "was" | "were" | "do" | "does" | "did" | "can" => QuestionType::YesNo,
            _ => QuestionType::General
    
    fn classify_command_type(&self, input: &str) -> CommandType:
        let first_word = input.split_whitespace().next().unwrap_or("")
        
        match first_word:
            "remember" => CommandType::Remember,
            "forget" => CommandType::Forget,
            "learn" => CommandType::Learn,
            "explain" | "describe" => CommandType::Explain,
            "summarize" => CommandType::Summarize,
            "compare" => CommandType::Compare,
            "list" => CommandType::List,
            "show" | "display" => CommandType::Show,
            "search" | "find" => CommandType::Search,
            "help" => CommandType::Help,
            "calculate" | "compute" => CommandType::Calculate,
            "create" | "make" => CommandType::Create,
            _ => CommandType::Generic

# ============================================================================
# ENTITY RECOGNITION
# ============================================================================

struct EntityRecognizer:
    # Built-in entity types
    date_patterns: Vec<String>
    number_patterns: Vec<String>
    known_entities: Map<String, EntityType>
    
    fn new() -> own EntityRecognizer:
        return EntityRecognizer {
            date_patterns: Self::default_date_patterns(),
            number_patterns: Self::default_number_patterns(),
            known_entities: Map::new()
        }
    
    fn extract(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        
        # Extract dates
        entities.extend(self.extract_dates(input))
        
        # Extract numbers
        entities.extend(self.extract_numbers(input))
        
        # Extract known entities
        entities.extend(self.extract_known_entities(input))
        
        # Extract quoted strings
        entities.extend(self.extract_quoted(input))
        
        # Extract capitalized words (potential proper nouns)
        entities.extend(self.extract_proper_nouns(input))
        
        return entities
    
    fn extract_dates(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        
        # Simple date patterns
        let date_words = ["today", "yesterday", "tomorrow", "monday", "tuesday",
                          "wednesday", "thursday", "friday", "saturday", "sunday"]
        
        for word in input.split_whitespace():
            let lower = word.to_lowercase()
            if date_words.contains(&lower.as_str()):
                entities.push(Entity {
                    text: word.to_string(),
                    entity_type: EntityType::Date,
                    confidence: 0.9,
                    start: input.find(word).unwrap_or(0),
                    end: input.find(word).unwrap_or(0) + word.len()
                })
        
        return entities
    
    fn extract_numbers(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        
        for word in input.split_whitespace():
            # Check if it's a number
            if word.parse::<f64>().is_ok():
                entities.push(Entity {
                    text: word.to_string(),
                    entity_type: EntityType::Number,
                    confidence: 1.0,
                    start: input.find(word).unwrap_or(0),
                    end: input.find(word).unwrap_or(0) + word.len()
                })
        
        return entities
    
    fn extract_known_entities(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        
        for (name, entity_type) in &self.known_entities:
            if input.to_lowercase().contains(&name.to_lowercase()):
                entities.push(Entity {
                    text: name.clone(),
                    entity_type: entity_type.clone(),
                    confidence: 1.0,
                    start: input.to_lowercase().find(&name.to_lowercase()).unwrap_or(0),
                    end: input.to_lowercase().find(&name.to_lowercase()).unwrap_or(0) + name.len()
                })
        
        return entities
    
    fn extract_quoted(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        let mut in_quote = false
        let mut quote_start = 0
        let mut current_quote = String::new()
        
        for (i, c) in input.chars().enumerate():
            if c == '"' || c == '\'' || c == '"' || c == '"':
                if in_quote:
                    entities.push(Entity {
                        text: current_quote.clone(),
                        entity_type: EntityType::QuotedText,
                        confidence: 1.0,
                        start: quote_start,
                        end: i
                    })
                    current_quote.clear()
                    in_quote = false
                else:
                    in_quote = true
                    quote_start = i + 1
            else if in_quote:
                current_quote.push(c)
        
        return entities
    
    fn extract_proper_nouns(&self, input: &str) -> Vec<Entity>:
        let mut entities = Vec::new()
        let words: Vec<&str> = input.split_whitespace().collect()
        
        for (i, word) in words.iter().enumerate():
            # Skip first word (might be capitalized due to sentence start)
            if i == 0:
                continue
            
            if word.chars().next().map(|c| c.is_uppercase()).unwrap_or(false):
                let clean = word.trim_matches(|c: char| !c.is_alphanumeric())
                if clean.len() > 1:
                    entities.push(Entity {
                        text: clean.to_string(),
                        entity_type: EntityType::ProperNoun,
                        confidence: 0.7,
                        start: input.find(word).unwrap_or(0),
                        end: input.find(word).unwrap_or(0) + word.len()
                    })
        
        return entities
    
    fn add_known_entity(&mut self, name: &str, entity_type: EntityType):
        self.known_entities.insert(name.to_string(), entity_type)
    
    fn default_date_patterns() -> Vec<String>:
        vec![
            r"\d{1,2}/\d{1,2}/\d{2,4}".to_string(),
            r"\d{1,2}-\d{1,2}-\d{2,4}".to_string(),
            r"\d{4}-\d{2}-\d{2}".to_string(),
        ]
    
    fn default_number_patterns() -> Vec<String>:
        vec![
            r"\d+".to_string(),
            r"\d+\.\d+".to_string(),
            r"-?\d+".to_string(),
        ]

# ============================================================================
# QUERY EXECUTOR
# ============================================================================

# Execute parsed queries against knowledge base
struct QueryExecutor:
    knowledge_graph: &kg::KnowledgeGraph
    reasoning_engine: &re::ReasoningEngine
    memory_system: &mem::MemorySystem
    
    fn new(kg: &kg::KnowledgeGraph, re: &re::ReasoningEngine, 
           mem: &mem::MemorySystem) -> own QueryExecutor:
        return QueryExecutor {
            knowledge_graph: kg,
            reasoning_engine: re,
            memory_system: mem
        }
    
    fn execute(&self, query: &ParsedQuery) -> QueryResult:
        log::debug("Executing query with intent: {:?}", query.intent)
        
        match &query.intent:
            Intent::Question(q_type) => {
                self.execute_question(query, q_type)
            }
            Intent::Command(c_type) => {
                self.execute_command(query, c_type)
            }
            Intent::Statement => {
                self.process_statement(query)
            }
            Intent::Greeting => {
                QueryResult::Text("Hello! How can I help you?".to_string())
            }
            Intent::Farewell => {
                QueryResult::Text("Goodbye!".to_string())
            }
            Intent::Unknown => {
                QueryResult::Text("I'm not sure I understand. Could you rephrase?".to_string())
            }
    
    fn execute_question(&self, query: &ParsedQuery, q_type: &QuestionType) -> QueryResult:
        match q_type:
            QuestionType::Definition => {
                # Look up definition in knowledge graph
                if let QueryStructure::Question { subject, .. } = &query.structure:
                    if let Some(subj) = subject:
                        let results = self.knowledge_graph.query(&kg::GraphPattern::Node {
                            node_type: None,
                            name_pattern: Some(subj.clone())
                        })
                        
                        if !results.is_empty():
                            return self.format_definition_results(results)
                
                QueryResult::NotFound("I don't have information about that.".to_string())
            }
            
            QuestionType::YesNo => {
                # Use reasoning engine to determine truth
                if let QueryStructure::Question { subject, predicate, object, .. } = &query.structure:
                    if let (Some(s), Some(p), Some(o)) = (subject, predicate, object):
                        let proposition = format!("{} {} {}", s, p, o)
                        # Would use reasoning engine here
                        return QueryResult::Boolean(true, 0.5)
                
                QueryResult::Text("I cannot determine that.".to_string())
            }
            
            QuestionType::Location => {
                if let Some(entity) = query.entities.first():
                    let edges = self.knowledge_graph.find_edges(
                        None, None, Some(&kg::Relation::LocatedAt)
                    )
                    # Filter for entity
                    for edge in edges:
                        if let Some(node) = self.knowledge_graph.get_node(edge.from_id):
                            if node.name.to_lowercase().contains(&entity.text.to_lowercase()):
                                if let Some(location) = self.knowledge_graph.get_node(edge.to_id):
                                    return QueryResult::Text(
                                        format!("{} is located at {}", node.name, location.name)
                                    )
                
                QueryResult::NotFound("I don't know the location.".to_string())
            }
            
            _ => {
                # General knowledge lookup
                let memory_query = mem::MemoryQuery {
                    text: query.normalized.clone(),
                    target: mem::MemoryTarget::Any,
                    max_results: 5,
                    time_range: None,
                    min_relevance: 0.0
                }
                
                let memories = self.memory_system.recall(&memory_query)
                
                if !memories.is_empty():
                    QueryResult::Memories(memories)
                else:
                    QueryResult::NotFound("I don't have information about that.".to_string())
            }
    
    fn execute_command(&self, query: &ParsedQuery, c_type: &CommandType) -> QueryResult:
        match c_type:
            CommandType::Help => {
                QueryResult::Text(self.help_text())
            }
            
            CommandType::Search => {
                let memory_query = mem::MemoryQuery {
                    text: query.normalized.clone(),
                    target: mem::MemoryTarget::Any,
                    max_results: 10,
                    time_range: None,
                    min_relevance: 0.0
                }
                
                let memories = self.memory_system.recall(&memory_query)
                QueryResult::Memories(memories)
            }
            
            CommandType::List => {
                # List related items from knowledge graph
                QueryResult::Text("Listing...".to_string())
            }
            
            _ => {
                QueryResult::Text("Command acknowledged.".to_string())
            }
    
    fn process_statement(&self, query: &ParsedQuery) -> QueryResult:
        # Statement could be adding new knowledge
        QueryResult::Text("I've noted that.".to_string())
    
    fn format_definition_results(&self, results: Vec<kg::QueryMatch>) -> QueryResult:
        let mut text = String::new()
        
        for result in results:
            if let kg::QueryMatch::Single(node_id) = result:
                if let Some(node) = self.knowledge_graph.get_node(node_id):
                    text.push_str(&format!("{}: ", node.name))
                    
                    # Get properties as definition
                    if let Some(def) = node.get_property("definition"):
                        text.push_str(&def.to_string())
                    else:
                        text.push_str("(No definition available)")
                    
                    text.push('\n')
        
        if text.is_empty():
            QueryResult::NotFound("No definition found.".to_string())
        else:
            QueryResult::Text(text)
    
    fn help_text(&self) -> String:
        "HELIOS Cognitive Assistant\n\
         Available commands:\n\
         - Ask questions: 'What is X?', 'Who is Y?', 'Where is Z?'\n\
         - Search: 'Find information about X'\n\
         - Remember: 'Remember that X is Y'\n\
         - Forget: 'Forget X'\n\
         - Help: Show this message".to_string()

# ============================================================================
# DATA STRUCTURES
# ============================================================================

struct ParsedQuery:
    original: String
    normalized: String
    intent: Intent
    entities: Vec<Entity>
    structure: QueryStructure
    confidence: f64

enum Intent:
    Question(q_type: QuestionType)
    Command(c_type: CommandType)
    Statement
    Greeting
    Farewell
    Unknown

enum QuestionType:
    Definition    # What is X?
    Identity      # Who is X?
    Location      # Where is X?
    Temporal      # When did X?
    Reason        # Why X?
    Method        # How does X?
    Quantity      # How many X?
    Selection     # Which X?
    YesNo         # Is X Y?
    Capability    # Can X?
    General       # Other questions

enum CommandType:
    Remember
    Forget
    Learn
    Explain
    Summarize
    Compare
    List
    Show
    Search
    Help
    Calculate
    Create
    Generic

enum QueryStructure:
    Question {
        question_type: QuestionType
        subject: Option<String>
        predicate: Option<String>
        object: Option<String>
        modifiers: Vec<String>
    }
    Command {
        command_type: CommandType
        target: Option<String>
        parameters: Map<String, Value>
    }
    Statement {
        subject: Option<String>
        predicate: Option<String>
        object: Option<String>
    }
    Simple(text: String)

struct Entity:
    text: String
    entity_type: EntityType
    confidence: f64
    start: usize
    end: usize

enum EntityType:
    Person
    Place
    Organization
    Date
    Time
    Number
    Currency
    Percentage
    ProperNoun
    QuotedText
    Unknown

struct QuestionPattern:
    pattern: String
    question_type: QuestionType
    
    fn new(pattern: &str, q_type: QuestionType) -> own QuestionPattern:
        QuestionPattern { pattern: pattern.to_string(), question_type: q_type }
    
    fn try_match(&self, input: &str) -> Option<PatternMatch>:
        # Simple pattern matching
        if input.starts_with(self.pattern.split('(').next().unwrap_or("")):
            return Some(PatternMatch {
                subject: None,
                predicate: None,
                object: None,
                modifiers: Vec::new()
            })
        None

struct CommandPattern:
    pattern: String
    command_type: CommandType
    
    fn new(pattern: &str, c_type: CommandType) -> own CommandPattern:
        CommandPattern { pattern: pattern.to_string(), command_type: c_type }
    
    fn try_match(&self, input: &str) -> Option<CommandMatch>:
        if input.starts_with(self.pattern.split('(').next().unwrap_or("")):
            return Some(CommandMatch {
                target: Some(input.to_string()),
                parameters: Map::new()
            })
        None

struct PatternMatch:
    subject: Option<String>
    predicate: Option<String>
    object: Option<String>
    modifiers: Vec<String>

struct CommandMatch:
    target: Option<String>
    parameters: Map<String, Value>

enum QueryResult:
    Text(content: String)
    Boolean(value: bool, confidence: f64)
    Number(value: f64)
    Memories(items: Vec<mem::MemoryItem>)
    NotFound(message: String)
    Error(message: String)
