# ============================================================================
# Three-Point Macro Scoping (Definition, Invocation, Usage)
# ============================================================================

enum MacroScope:
    DefinitionSite      # Scope where macro was defined
    InvocationSite      # Scope where macro is invoked
    ExpansionSite       # Scope where expanded code is inserted

struct ScopedIdentifier:
    name: str
    scope: MacroScope
    binding_id: NodeId

# When an identifier is referenced in macro expansion:
# 1. Look in definition site scope first (prevents capture)
# 2. If not found, look in invocation site scope (macro parameter)
# 3. If still not found, treat as undefined error

impl ScopedIdentifier:
    fn resolve(
        &self,
        def_scope: &SymbolTable,
        call_scope: &SymbolTable,
    ) -> Option<NodeId>:
        match self.scope:
            MacroScope::DefinitionSite =>
                def_scope.lookup(&self.name)
            MacroScope::InvocationSite =>
                call_scope.lookup(&self.name)
            MacroScope::ExpansionSite =>
                # Try definition site first, then call site
                match def_scope.lookup(&self.name):
                    Some(id) => Some(id)
                    None => call_scope.lookup(&self.name)

# ============================================================================
# Macro Variable Capture Detection
# ============================================================================

struct CaptureFinder:
    captured: Vec<(str, NodeId)>

impl CaptureFinder:
    fn new() -> own Self:
        return CaptureFinder {
            captured: Vec::new(),
        }
    
    # Traverse macro body and find all free variables
    fn find_free_variables(&mut self, expr: &Expr, def_scope: &SymbolTable) -> Vec<str>:
        let mut free_vars = Vec::new()
        
        # Traverse expression tree and identify unbound identifiers
        # (This is a simplified illustration; real implementation would be recursive)
        
        # For now, return empty—full AST traversal needed
        return free_vars
    
    # Check if macro would shadow any variables in caller's scope
    fn would_capture(
        &self,
        macro_body: &Expr,
        def_scope: &SymbolTable,
        call_scope: &SymbolTable,
    ) -> Vec<str>:
        let free_vars = self.find_free_variables(macro_body, def_scope)
        
        let mut captured = Vec::new()
        
        for var in free_vars:
            # If variable exists in call scope, it would be captured
            match call_scope.lookup(&var):
                Some(_) => captured.push(var)
                None => pass
        
        return captured

# ============================================================================
# Macro Export (Public vs Private)
# ============================================================================

# By default, macros are private (definition-site scoped)
# Macro definitions can be exported with `pub` keyword:
#
# pub macro assert(condition, message):
#     if not condition:
#         panic(message)
#
# Private macros are only visible within their definition module
# Public macros can be imported and used in other modules

struct MacroExport:
    name: str
    is_public: bool
    definition_module: str
    visibility_scope: ScopeId

# ============================================================================
# Hygiene Rules Summary
# ============================================================================

# 1. VARIABLE INTRODUCTION (let, fn, struct, etc.)
#    - Variables introduced in macro body get definition-site scope
#    - Prevents macro from accidentally creating variables in caller's scope
#
# 2. VARIABLE REFERENCE
#    - Variables referenced in macro first look in definition site
#    - Then look in macro parameters
#    - Then look in invocation site (call site)
#    - Prevents macro from accessing caller's local variables unintentionally
#
# 3. IDENTIFIER COLLISION
#    - If macro introduces identifier that collides with caller's scope,
#      the macro's version shadows it
#    - Caller's scope is still accessible via qualified names if needed
#
# 4. PARAMETER SUBSTITUTION
#    - Macro parameters are substituted literally (no hygiene needed)
#    - But recursive substitution checks for variable capture
#
# 5. VARIADIC PARAMETERS
#    - Variadic args maintain argument-site scope
#    - Prevents hygiene violation when expanding ...args
