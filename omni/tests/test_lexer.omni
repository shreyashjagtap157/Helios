module tests::lexer

# ============================================================================
# Lexer Tests — Comprehensive test suite for the tokenizer
# ============================================================================

import compiler::lexer::token::{Token, TokenKind, Span, lookup_keyword}
import compiler::lexer::mod::{Lexer, tokenize}
import std::core::{String, Vector, assert, assert_eq}

# ============================================================================
# Token Kind Tests
# ============================================================================

#[test]
fn test_keywords():
    assert_eq(lookup_keyword("fn"), Some(TokenKind::Fn))
    assert_eq(lookup_keyword("let"), Some(TokenKind::Let))
    assert_eq(lookup_keyword("mut"), Some(TokenKind::Mut))
    assert_eq(lookup_keyword("if"), Some(TokenKind::If))
    assert_eq(lookup_keyword("else"), Some(TokenKind::Else))
    assert_eq(lookup_keyword("while"), Some(TokenKind::While))
    assert_eq(lookup_keyword("for"), Some(TokenKind::For))
    assert_eq(lookup_keyword("in"), Some(TokenKind::In))
    assert_eq(lookup_keyword("return"), Some(TokenKind::Return))
    assert_eq(lookup_keyword("struct"), Some(TokenKind::Struct))
    assert_eq(lookup_keyword("enum"), Some(TokenKind::Enum))
    assert_eq(lookup_keyword("trait"), Some(TokenKind::Trait))
    assert_eq(lookup_keyword("impl"), Some(TokenKind::Impl))
    assert_eq(lookup_keyword("import"), Some(TokenKind::Import))
    assert_eq(lookup_keyword("module"), Some(TokenKind::Module))
    assert_eq(lookup_keyword("match"), Some(TokenKind::Match))
    assert_eq(lookup_keyword("true"), Some(TokenKind::True))
    assert_eq(lookup_keyword("false"), Some(TokenKind::False))
    assert_eq(lookup_keyword("self"), Some(TokenKind::SelfValue))
    assert_eq(lookup_keyword("Self"), Some(TokenKind::SelfType))
    assert_eq(lookup_keyword("not_a_keyword"), None)
    assert_eq(lookup_keyword("FN"), None)

#[test]
fn test_span():
    let span = Span { file_id: 1, start: 10, end: 20, line: 3, column: 5 }
    assert_eq(span.len(), 10)
    assert_eq(span.line, 3)
    assert_eq(span.column, 5)

# ============================================================================
# Simple Token Tests
# ============================================================================

#[test]
fn test_empty_input():
    let tokens = tokenize("")
    assert(tokens.len() >= 1, "should have at least EOF")
    assert_eq(tokens.last().unwrap().kind, TokenKind::Eof)

#[test]
fn test_integer_literals():
    let tokens = tokenize("42 0 123456 0xFF 0b1010 0o77")
    assert(find_token(&tokens, TokenKind::IntLit), "should find int literals")

#[test]
fn test_float_literals():
    let tokens = tokenize("3.14 0.0 1.0e10 2.5e-3 1.0f32")
    assert(find_token(&tokens, TokenKind::FloatLit), "should find float literals")

#[test]
fn test_string_literals():
    let tokens = tokenize("\"hello\" \"world\" \"escape\\n\" \"\"")
    assert(find_token(&tokens, TokenKind::StringLit), "should find string literals")

#[test]
fn test_char_literals():
    let tokens = tokenize("'a' 'Z' '\\n' '\\t' '\\0'")
    assert(find_token(&tokens, TokenKind::CharLit), "should find char literals")

#[test]
fn test_operators():
    let tokens = tokenize("+ - * / % == != < > <= >= && || ! & | ^ ~ << >>")
    assert(find_token(&tokens, TokenKind::Plus), "plus")
    assert(find_token(&tokens, TokenKind::Minus), "minus")
    assert(find_token(&tokens, TokenKind::Star), "star")
    assert(find_token(&tokens, TokenKind::Slash), "slash")
    assert(find_token(&tokens, TokenKind::EqEq), "eq_eq")
    assert(find_token(&tokens, TokenKind::NotEq), "not_eq")

#[test]
fn test_delimiters():
    let tokens = tokenize("( ) [ ] { } , ; :: -> => .")
    assert(find_token(&tokens, TokenKind::LParen), "lparen")
    assert(find_token(&tokens, TokenKind::RParen), "rparen")
    assert(find_token(&tokens, TokenKind::LBracket), "lbracket")
    assert(find_token(&tokens, TokenKind::RBracket), "rbracket")
    assert(find_token(&tokens, TokenKind::LBrace), "lbrace")
    assert(find_token(&tokens, TokenKind::RBrace), "rbrace")
    assert(find_token(&tokens, TokenKind::Comma), "comma")
    assert(find_token(&tokens, TokenKind::ColonColon), "colon_colon")
    assert(find_token(&tokens, TokenKind::Arrow), "arrow")
    assert(find_token(&tokens, TokenKind::FatArrow), "fat_arrow")

#[test]
fn test_identifiers():
    let tokens = tokenize("foo bar _baz camelCase UPPER x1 _0")
    assert(find_token(&tokens, TokenKind::Ident), "should find identifiers")

# ============================================================================
# Indentation Tests
# ============================================================================

#[test]
fn test_indent_dedent():
    let source = "fn main():\n    let x = 5\n    let y = 10\n"
    let tokens = tokenize(source)
    assert(find_token(&tokens, TokenKind::Indent), "should find INDENT")
    assert(find_token(&tokens, TokenKind::Dedent), "should find DEDENT")

#[test]
fn test_nested_indent():
    let source = "fn foo():\n    if true:\n        return 1\n    return 0\n"
    let tokens = tokenize(source)
    let indent_count = count_token(&tokens, TokenKind::Indent)
    let dedent_count = count_token(&tokens, TokenKind::Dedent)
    assert(indent_count == 2, "should have 2 indents")
    assert(dedent_count == 2, "should have 2 dedents")

#[test]
fn test_bracket_suppresses_indent():
    let source = "let x = [\n    1,\n    2,\n    3,\n]\n"
    let tokens = tokenize(source)
    let indent_count = count_token(&tokens, TokenKind::Indent)
    assert(indent_count == 0, "brackets should suppress indent tokens")

# ============================================================================
# Comment Tests
# ============================================================================

#[test]
fn test_line_comment():
    let tokens = tokenize("x # this is a comment\ny")
    assert(not find_token(&tokens, TokenKind::Comment), "comments should be skipped")

#[test]
fn test_block_comment():
    let tokens = tokenize("x /* block\ncomment */ y")
    let ident_count = count_token(&tokens, TokenKind::Ident)
    assert(ident_count == 2, "should have 2 identifiers around block comment")

# ============================================================================
# Complex Expression Tests
# ============================================================================

#[test]
fn test_function_definition():
    let source = "fn add(a: i32, b: i32) -> i32:\n    return a + b\n"
    let tokens = tokenize(source)
    assert(find_token(&tokens, TokenKind::Fn), "fn keyword")
    assert(find_token(&tokens, TokenKind::Arrow), "return arrow")
    assert(find_token(&tokens, TokenKind::Return), "return keyword")

#[test]
fn test_struct_definition():
    let source = "struct Point:\n    x: f64\n    y: f64\n"
    let tokens = tokenize(source)
    assert(find_token(&tokens, TokenKind::Struct), "struct keyword")
    assert(find_token(&tokens, TokenKind::Colon), "colon")

#[test]
fn test_generic_syntax():
    let source = "fn identity<T>(x: T) -> T:\n    return x\n"
    let tokens = tokenize(source)
    assert(find_token(&tokens, TokenKind::Lt), "less than / generic open")
    assert(find_token(&tokens, TokenKind::Gt), "greater than / generic close")

#[test]
fn test_match_expression():
    let source = "match value:\n    Some(x) => x\n    None => 0\n"
    let tokens = tokenize(source)
    assert(find_token(&tokens, TokenKind::Match), "match keyword")
    assert(find_token(&tokens, TokenKind::FatArrow), "fat arrow")

# ============================================================================
# Edge Cases
# ============================================================================

#[test]
fn test_consecutive_operators():
    let tokens = tokenize("a+b*c-d")
    assert(find_token(&tokens, TokenKind::Plus), "plus")
    assert(find_token(&tokens, TokenKind::Star), "star")
    assert(find_token(&tokens, TokenKind::Minus), "minus")

#[test]
fn test_multiline_string():
    let tokens = tokenize("\"line1\\nline2\\nline3\"")
    assert(find_token(&tokens, TokenKind::StringLit), "multiline string")

#[test]
fn test_underscore_in_numbers():
    let tokens = tokenize("1_000_000 0xFF_FF 0b1010_0101")
    assert(find_token(&tokens, TokenKind::IntLit), "underscored number")

#[test]
fn test_range_operator():
    let tokens = tokenize("0..10 0..=10")
    assert(find_token(&tokens, TokenKind::DotDot), "range operator")

# ============================================================================
# Error Recovery Tests
# ============================================================================

#[test]
fn test_unterminated_string():
    let tokens = tokenize("\"unterminated")
    assert(find_token(&tokens, TokenKind::Error), "should produce error token")

#[test]
fn test_invalid_character():
    let tokens = tokenize("@")
    assert(find_token(&tokens, TokenKind::Error), "should produce error token for @")

# ============================================================================
# Helper Functions
# ============================================================================

fn find_token(tokens: &Vector<Token>, kind: TokenKind) -> bool:
    for t in tokens.iter():
        if t.kind == kind:
            return true
    return false

fn count_token(tokens: &Vector<Token>, kind: TokenKind) -> u32:
    let mut count: u32 = 0
    for t in tokens.iter():
        if t.kind == kind:
            count += 1
    return count
