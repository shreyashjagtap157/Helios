module tests::semantic

# ============================================================================
# Semantic Analysis Tests — Type checking, borrow checking, trait resolution
# ============================================================================

import compiler::semantic::mod::{SemanticAnalyzer, analyze}
import compiler::semantic::types::{Type, PrimitiveKind, TypeTable}
import compiler::semantic::borrow::{BorrowChecker, Ownership}
import compiler::semantic::traits::{TraitResolver}
import compiler::semantic::mono::{Monomorphizer}
import compiler::parser::mod::{parse}
import compiler::lexer::mod::{tokenize}
import std::core::{String, Vector, Result, Ok, Err, assert, assert_eq}

# ============================================================================
# Type Checking Tests
# ============================================================================

#[test]
fn test_integer_type_inference():
    let result = type_of_expr("42")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::I32)))

#[test]
fn test_float_type_inference():
    let result = type_of_expr("3.14")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::F64)))

#[test]
fn test_bool_type():
    let result = type_of_expr("true")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::Bool)))

#[test]
fn test_string_type():
    let result = type_of_expr("\"hello\"")
    assert_eq(result, Ok(Type::String))

#[test]
fn test_binary_type_inference():
    let result = type_of_expr("1 + 2")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::I32)))

#[test]
fn test_float_binary():
    let result = type_of_expr("1.0 + 2.0")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::F64)))

#[test]
fn test_comparison_returns_bool():
    let result = type_of_expr("1 < 2")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::Bool)))

#[test]
fn test_logical_op_returns_bool():
    let result = type_of_expr("true && false")
    assert_eq(result, Ok(Type::Primitive(PrimitiveKind::Bool)))

#[test]
fn test_type_mismatch_error():
    let result = check_program("fn main():\n    let x: i32 = \"hello\"\n")
    assert(result.is_err(), "should detect type mismatch")

#[test]
fn test_let_binding_inference():
    let result = check_program("fn main():\n    let x = 42\n    let y: i32 = x\n")
    assert(result.is_ok(), "should infer let binding type")

#[test]
fn test_function_return_type_check():
    let result = check_program("fn foo() -> i32:\n    return \"not int\"\n")
    assert(result.is_err(), "should detect return type mismatch")

#[test]
fn test_function_call_type():
    let result = check_program("fn add(a: i32, b: i32) -> i32:\n    return a + b\n\nfn main():\n    let x: i32 = add(1, 2)\n")
    assert(result.is_ok(), "function call should return correct type")

#[test]
fn test_wrong_arg_count():
    let result = check_program("fn foo(a: i32) -> i32:\n    return a\n\nfn main():\n    foo(1, 2)\n")
    assert(result.is_err(), "should detect wrong argument count")

#[test]
fn test_wrong_arg_type():
    let result = check_program("fn foo(a: i32) -> i32:\n    return a\n\nfn main():\n    foo(\"string\")\n")
    assert(result.is_err(), "should detect wrong argument type")

# ============================================================================
# Generics Tests
# ============================================================================

#[test]
fn test_generic_function():
    let result = check_program("fn identity<T>(x: T) -> T:\n    return x\n\nfn main():\n    let a: i32 = identity(42)\n    let b: String = identity(\"hello\")\n")
    assert(result.is_ok(), "generic function should type-check")

#[test]
fn test_generic_struct():
    let result = check_program("struct Pair<A, B>:\n    first: A\n    second: B\n\nfn main():\n    let p = Pair { first: 1, second: \"two\" }\n")
    assert(result.is_ok(), "generic struct should type-check")

#[test]
fn test_generic_constraint():
    let result = check_program("fn compare<T: PartialOrd>(a: T, b: T) -> bool:\n    return a < b\n\nfn main():\n    let r = compare(1, 2)\n")
    assert(result.is_ok(), "constrained generic should type-check")

# ============================================================================
# Option/Result Tests
# ============================================================================

#[test]
fn test_option_type():
    let result = check_program("fn find(x: i32) -> Option<i32>:\n    if x > 0:\n        return Some(x)\n    return None\n")
    assert(result.is_ok(), "Option return type should check")

#[test]
fn test_result_type():
    let result = check_program("fn parse(s: &str) -> Result<i32, String>:\n    return Ok(42)\n")
    assert(result.is_ok(), "Result return type should check")

# ============================================================================
# Borrow Checking Tests
# ============================================================================

#[test]
fn test_immutable_borrow():
    let result = check_program("fn main():\n    let x = 5\n    let r1 = &x\n    let r2 = &x\n    println!(\"{} {}\", r1, r2)\n")
    assert(result.is_ok(), "multiple immutable borrows should be allowed")

#[test]
fn test_mutable_borrow():
    let result = check_program("fn main():\n    let mut x = 5\n    let r = &mut x\n    *r = 10\n")
    assert(result.is_ok(), "single mutable borrow should be allowed")

#[test]
fn test_no_aliased_mut_borrows():
    let result = check_program("fn main():\n    let mut x = 5\n    let r1 = &mut x\n    let r2 = &mut x\n    *r1 = 10\n")
    assert(result.is_err(), "aliased mutable borrows should be rejected")

#[test]
fn test_no_mut_while_immutable_borrowed():
    let result = check_program("fn main():\n    let mut x = 5\n    let r = &x\n    x = 10\n    println!(\"{}\", r)\n")
    assert(result.is_err(), "mutation during immutable borrow should be rejected")

#[test]
fn test_move_semantics():
    let result = check_program("fn main():\n    let s = String::from(\"hello\")\n    let t = s\n    println!(\"{}\", s)\n")
    assert(result.is_err(), "use after move should be rejected")

#[test]
fn test_copy_types():
    let result = check_program("fn main():\n    let x: i32 = 5\n    let y = x\n    println!(\"{} {}\", x, y)\n")
    assert(result.is_ok(), "copy types should allow use after copy")

#[test]
fn test_borrow_in_loop():
    let result = check_program("fn main():\n    let mut v = Vector::new()\n    for i in 0..10:\n        v.push(i)\n    let r = &v\n    println!(\"{}\", r.len())\n")
    assert(result.is_ok(), "borrow after loop should be ok")

#[test]
fn test_return_local_reference():
    let result = check_program("fn bad() -> &i32:\n    let x = 5\n    return &x\n")
    assert(result.is_err(), "returning reference to local should be rejected")

# ============================================================================
# Trait Resolution Tests
# ============================================================================

#[test]
fn test_trait_impl():
    let result = check_program("trait Greet:\n    fn greet(&self) -> String\n\nstruct Person:\n    name: String\n\nimpl Greet for Person:\n    fn greet(&self) -> String:\n        return format!(\"Hello, {}!\", self.name)\n")
    assert(result.is_ok(), "trait impl should type-check")

#[test]
fn test_missing_trait_method():
    let result = check_program("trait Greet:\n    fn greet(&self) -> String\n    fn farewell(&self) -> String\n\nstruct Person:\n    name: String\n\nimpl Greet for Person:\n    fn greet(&self) -> String:\n        return String::from(\"hi\")\n")
    assert(result.is_err(), "missing trait method should be rejected")

#[test]
fn test_wrong_trait_method_signature():
    let result = check_program("trait Greet:\n    fn greet(&self) -> String\n\nstruct Person:\n    name: String\n\nimpl Greet for Person:\n    fn greet(&self) -> i32:\n        return 42\n")
    assert(result.is_err(), "wrong method return type should be rejected")

#[test]
fn test_trait_bound():
    let result = check_program("trait Summary:\n    fn summarize(&self) -> String\n\nfn print_summary<T: Summary>(item: &T):\n    println!(\"{}\", item.summarize())\n")
    assert(result.is_ok(), "trait bound should type-check")

#[test]
fn test_multiple_trait_bounds():
    let result = check_program("fn process<T: Debug + Clone>(item: T):\n    let copy = item.clone()\n    println!(\"{:?}\", copy)\n")
    assert(result.is_ok(), "multiple trait bounds should type-check")

#[test]
fn test_default_method():
    let result = check_program("trait Describable:\n    fn name(&self) -> String\n    fn describe(&self) -> String:\n        return format!(\"Item: {}\", self.name())\n")
    assert(result.is_ok(), "default trait method should type-check")

# ============================================================================
# Monomorphization Tests
# ============================================================================

#[test]
fn test_mono_generic_function():
    let result = mono_check("fn id<T>(x: T) -> T:\n    return x\n\nfn main():\n    let a = id(42)\n    let b = id(\"hello\")\n")
    assert(result.is_ok(), "monomorphization should succeed")
    let mono = result.unwrap()
    assert(mono.specializations >= 2, "should create at least 2 specializations")

#[test]
fn test_mono_dead_code_elimination():
    let result = mono_check("fn unused<T>(x: T) -> T:\n    return x\n\nfn main():\n    println!(\"hello\")\n")
    assert(result.is_ok(), "should succeed")
    let mono = result.unwrap()
    assert(mono.specializations == 0, "unused generic should not be specialized")

# ============================================================================
# Pattern Matching Tests
# ============================================================================

#[test]
fn test_exhaustive_match():
    let result = check_program("enum Color:\n    Red\n    Green\n    Blue\n\nfn name(c: Color) -> String:\n    match c:\n        Color::Red => \"red\"\n        Color::Green => \"green\"\n        Color::Blue => \"blue\"\n")
    assert(result.is_ok(), "exhaustive match should pass")

#[test]
fn test_non_exhaustive_match():
    let result = check_program("enum Color:\n    Red\n    Green\n    Blue\n\nfn name(c: Color) -> String:\n    match c:\n        Color::Red => \"red\"\n        Color::Green => \"green\"\n")
    assert(result.is_err(), "non-exhaustive match should be rejected")

#[test]
fn test_wildcard_match():
    let result = check_program("fn describe(x: i32) -> String:\n    match x:\n        0 => \"zero\"\n        1 => \"one\"\n        _ => \"other\"\n")
    assert(result.is_ok(), "wildcard match should be exhaustive")

# ============================================================================
# Scope and Symbol Resolution Tests
# ============================================================================

#[test]
fn test_undefined_variable():
    let result = check_program("fn main():\n    println!(\"{}\", undefined_var)\n")
    assert(result.is_err(), "undefined variable should be rejected")

#[test]
fn test_undefined_function():
    let result = check_program("fn main():\n    undefined_func()\n")
    assert(result.is_err(), "undefined function should be rejected")

#[test]
fn test_shadowing():
    let result = check_program("fn main():\n    let x = 5\n    let x = \"hello\"\n    println!(\"{}\", x)\n")
    assert(result.is_ok(), "variable shadowing should be allowed")

#[test]
fn test_block_scope():
    let result = check_program("fn main():\n    if true:\n        let x = 5\n    println!(\"{}\", x)\n")
    assert(result.is_err(), "variable should not escape block scope")

# ============================================================================
# Integration Tests
# ============================================================================

#[test]
fn test_full_program():
    let source = """
module test

struct Point:
    x: f64
    y: f64

impl Point:
    fn new(x: f64, y: f64) -> own Point:
        return Point { x: x, y: y }

    fn distance(&self, other: &Point) -> f64:
        let dx = self.x - other.x
        let dy = self.y - other.y
        return (dx * dx + dy * dy).sqrt()

trait Shape:
    fn area(&self) -> f64
    fn perimeter(&self) -> f64

struct Circle:
    center: Point
    radius: f64

impl Shape for Circle:
    fn area(&self) -> f64:
        return 3.14159265 * self.radius * self.radius

    fn perimeter(&self) -> f64:
        return 2.0 * 3.14159265 * self.radius

fn main():
    let p1 = Point::new(0.0, 0.0)
    let p2 = Point::new(3.0, 4.0)
    let dist = p1.distance(&p2)
    assert(dist == 5.0, "distance")

    let c = Circle { center: Point::new(0.0, 0.0), radius: 1.0 }
    let a = c.area()
    println!("area = {}", a)
"""
    let result = check_program(source)
    assert(result.is_ok(), "full program should type-check")

# ============================================================================
# Helper Functions
# ============================================================================

fn type_of_expr(source: &str) -> Result<Type, String>:
    let tokens = tokenize(source)
    let expr = parse_expression(tokens)
    let mut analyzer = SemanticAnalyzer::new()
    return analyzer.infer_type(&expr)

fn check_program(source: &str) -> Result<(), String>:
    let tokens = tokenize(source)
    let ast = parse(tokens)
    let mut analyzer = SemanticAnalyzer::new()
    return analyzer.check(&ast)

struct MonoResult:
    specializations: u32

fn mono_check(source: &str) -> Result<MonoResult, String>:
    let tokens = tokenize(source)
    let ast = parse(tokens)
    let mut analyzer = SemanticAnalyzer::new()
    analyzer.check(&ast)?
    let mut mono = Monomorphizer::new()
    let specs = mono.monomorphize(&ast)?
    return Ok(MonoResult { specializations: specs.len() as u32 })
