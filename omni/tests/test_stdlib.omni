module tests::stdlib

# ============================================================================
# Standard Library Tests — core, collections, io, math, ffi, threading
# ============================================================================

import std::core::{String, Option, Some, None, Result, Ok, Err, assert, assert_eq}
import std::collections::{Vector, HashMap, HashSet, VecDeque, BTreeMap}
import std::math
import std::mem::{Box, Rc, Arc, RefCell}
import std::io::{Path}

# ============================================================================
# String Tests
# ============================================================================

#[test]
fn test_string_new():
    let s = String::new()
    assert(s.is_empty(), "new string should be empty")
    assert_eq(s.len(), 0)

#[test]
fn test_string_from():
    let s = String::from("hello")
    assert_eq(s.len(), 5)
    assert_eq(s, "hello")

#[test]
fn test_string_push():
    let mut s = String::from("hello")
    s.push(' ')
    s.push_str("world")
    assert_eq(s, "hello world")

#[test]
fn test_string_contains():
    let s = String::from("hello world")
    assert(s.contains("world"), "should contain world")
    assert(not s.contains("xyz"), "should not contain xyz")

#[test]
fn test_string_starts_ends():
    let s = String::from("hello world")
    assert(s.starts_with("hello"), "starts_with")
    assert(s.ends_with("world"), "ends_with")

#[test]
fn test_string_find():
    let s = String::from("hello world")
    assert_eq(s.find("world"), Some(6))
    assert_eq(s.find("xyz"), None)

#[test]
fn test_string_split():
    let s = String::from("a,b,c")
    let parts = s.split(",")
    assert_eq(parts.len(), 3)
    assert_eq(parts[0], "a")
    assert_eq(parts[1], "b")
    assert_eq(parts[2], "c")

#[test]
fn test_string_trim():
    let s = String::from("  hello  ")
    assert_eq(s.trim(), "hello")
    assert_eq(s.trim_start(), "hello  ")
    assert_eq(s.trim_end(), "  hello")

#[test]
fn test_string_replace():
    let s = String::from("hello world")
    let r = s.replace("world", "omni")
    assert_eq(r, "hello omni")

#[test]
fn test_string_case():
    let s = String::from("Hello World")
    assert_eq(s.to_uppercase(), "HELLO WORLD")
    assert_eq(s.to_lowercase(), "hello world")

#[test]
fn test_string_substring():
    let s = String::from("hello world")
    let sub = s.substring(0, 5)
    assert_eq(sub, "hello")

# ============================================================================
# Option Tests
# ============================================================================

#[test]
fn test_option_some():
    let x: Option<i32> = Some(42)
    assert(x.is_some(), "should be Some")
    assert(not x.is_none(), "should not be None")
    assert_eq(x.unwrap(), 42)

#[test]
fn test_option_none():
    let x: Option<i32> = None
    assert(x.is_none(), "should be None")
    assert(not x.is_some(), "should not be Some")

#[test]
fn test_option_map():
    let x: Option<i32> = Some(5)
    let y = x.map(|v| v * 2)
    assert_eq(y, Some(10))

#[test]
fn test_option_and_then():
    let x: Option<i32> = Some(5)
    let y = x.and_then(|v| if v > 0: Some(v * 2) else: None)
    assert_eq(y, Some(10))

#[test]
fn test_option_unwrap_or():
    let x: Option<i32> = None
    assert_eq(x.unwrap_or(42), 42)

# ============================================================================
# Result Tests
# ============================================================================

#[test]
fn test_result_ok():
    let r: Result<i32, String> = Ok(42)
    assert(r.is_ok(), "should be Ok")
    assert_eq(r.unwrap(), 42)

#[test]
fn test_result_err():
    let r: Result<i32, String> = Err(String::from("error"))
    assert(r.is_err(), "should be Err")
    assert_eq(r.unwrap_err(), "error")

#[test]
fn test_result_map():
    let r: Result<i32, String> = Ok(5)
    let m = r.map(|v| v * 2)
    assert_eq(m, Ok(10))

# ============================================================================
# Vector Tests
# ============================================================================

#[test]
fn test_vector_new():
    let v: Vector<i32> = Vector::new()
    assert(v.is_empty(), "new vector should be empty")
    assert_eq(v.len(), 0)

#[test]
fn test_vector_push_pop():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    assert_eq(v.len(), 3)
    assert_eq(v.pop(), Some(3))
    assert_eq(v.pop(), Some(2))
    assert_eq(v.pop(), Some(1))
    assert_eq(v.pop(), None)

#[test]
fn test_vector_index():
    let mut v = Vector::new()
    v.push(10)
    v.push(20)
    v.push(30)
    assert_eq(v[0], 10)
    assert_eq(v[1], 20)
    assert_eq(v[2], 30)

#[test]
fn test_vector_insert_remove():
    let mut v = Vector::new()
    v.push(1)
    v.push(3)
    v.insert(1, 2)
    assert_eq(v.len(), 3)
    assert_eq(v[1], 2)

    let removed = v.remove(1)
    assert_eq(removed, 2)
    assert_eq(v.len(), 2)

#[test]
fn test_vector_sort():
    let mut v = Vector::new()
    v.push(5)
    v.push(3)
    v.push(8)
    v.push(1)
    v.push(4)
    v.sort()
    assert_eq(v[0], 1)
    assert_eq(v[1], 3)
    assert_eq(v[2], 4)
    assert_eq(v[3], 5)
    assert_eq(v[4], 8)

#[test]
fn test_vector_iter():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    let mut sum = 0
    for val in v.iter():
        sum += val
    assert_eq(sum, 6)

#[test]
fn test_vector_contains():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    assert(v.contains(&2), "should contain 2")
    assert(not v.contains(&5), "should not contain 5")

#[test]
fn test_vector_map():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    let doubled = v.iter().map(|x| x * 2).collect()
    assert_eq(doubled[0], 2)
    assert_eq(doubled[1], 4)
    assert_eq(doubled[2], 6)

#[test]
fn test_vector_filter():
    let mut v = Vector::new()
    for i in 0..10:
        v.push(i)
    let evens: Vector<i32> = v.iter().filter(|x| x % 2 == 0).collect()
    assert_eq(evens.len(), 5)

# ============================================================================
# HashMap Tests
# ============================================================================

#[test]
fn test_hashmap_new():
    let m: HashMap<String, i32> = HashMap::new()
    assert(m.is_empty(), "new map should be empty")

#[test]
fn test_hashmap_insert_get():
    let mut m = HashMap::new()
    m.insert(String::from("one"), 1)
    m.insert(String::from("two"), 2)
    m.insert(String::from("three"), 3)
    assert_eq(m.len(), 3)
    assert_eq(m.get(&String::from("one")), Some(&1))
    assert_eq(m.get(&String::from("two")), Some(&2))
    assert_eq(m.get(&String::from("four")), None)

#[test]
fn test_hashmap_remove():
    let mut m = HashMap::new()
    m.insert(String::from("key"), 42)
    let removed = m.remove(&String::from("key"))
    assert_eq(removed, Some(42))
    assert(m.is_empty(), "should be empty after removal")

#[test]
fn test_hashmap_contains():
    let mut m = HashMap::new()
    m.insert(String::from("key"), 42)
    assert(m.contains_key(&String::from("key")), "should contain key")
    assert(not m.contains_key(&String::from("other")), "should not contain other")

#[test]
fn test_hashmap_overwrite():
    let mut m = HashMap::new()
    m.insert(String::from("key"), 1)
    m.insert(String::from("key"), 2)
    assert_eq(m.get(&String::from("key")), Some(&2))
    assert_eq(m.len(), 1)

# ============================================================================
# HashSet Tests
# ============================================================================

#[test]
fn test_hashset():
    let mut s = HashSet::new()
    s.insert(1)
    s.insert(2)
    s.insert(3)
    s.insert(2)  # duplicate
    assert_eq(s.len(), 3)
    assert(s.contains(&2), "should contain 2")

#[test]
fn test_hashset_union():
    let mut a = HashSet::new()
    a.insert(1)
    a.insert(2)
    let mut b = HashSet::new()
    b.insert(2)
    b.insert(3)
    let u = a.union(&b)
    assert_eq(u.len(), 3)

#[test]
fn test_hashset_intersection():
    let mut a = HashSet::new()
    a.insert(1)
    a.insert(2)
    a.insert(3)
    let mut b = HashSet::new()
    b.insert(2)
    b.insert(3)
    b.insert(4)
    let inter = a.intersection(&b)
    assert_eq(inter.len(), 2)
    assert(inter.contains(&2), "should contain 2")
    assert(inter.contains(&3), "should contain 3")

# ============================================================================
# VecDeque Tests
# ============================================================================

#[test]
fn test_vecdeque():
    let mut d = VecDeque::new()
    d.push_back(1)
    d.push_back(2)
    d.push_front(0)
    assert_eq(d.len(), 3)
    assert_eq(d.pop_front(), Some(0))
    assert_eq(d.pop_back(), Some(2))
    assert_eq(d.pop_front(), Some(1))

# ============================================================================
# BTreeMap Tests
# ============================================================================

#[test]
fn test_btreemap():
    let mut m = BTreeMap::new()
    m.insert(3, "three")
    m.insert(1, "one")
    m.insert(2, "two")
    assert_eq(m.len(), 3)

    # BTreeMap iterates in sorted order
    let keys: Vector<i32> = m.keys().collect()
    assert_eq(keys[0], 1)
    assert_eq(keys[1], 2)
    assert_eq(keys[2], 3)

# ============================================================================
# Math Tests
# ============================================================================

#[test]
fn test_math_constants():
    assert(math::PI > 3.14 && math::PI < 3.15, "PI")
    assert(math::E > 2.71 && math::E < 2.72, "E")

#[test]
fn test_math_trig():
    let val = math::sin(math::PI / 2.0)
    assert(math::approx_eq(val, 1.0, 1e-10), "sin(π/2) ≈ 1")

    let val2 = math::cos(0.0)
    assert(math::approx_eq(val2, 1.0, 1e-10), "cos(0) ≈ 1")

#[test]
fn test_math_sqrt():
    assert(math::approx_eq(math::sqrt(4.0), 2.0, 1e-10), "sqrt(4) = 2")
    assert(math::approx_eq(math::sqrt(9.0), 3.0, 1e-10), "sqrt(9) = 3")

#[test]
fn test_math_pow():
    assert(math::approx_eq(math::pow(2.0, 10.0), 1024.0, 1e-6), "2^10 = 1024")

#[test]
fn test_math_log():
    assert(math::approx_eq(math::log(math::E), 1.0, 1e-10), "ln(e) = 1")

#[test]
fn test_math_floor_ceil():
    assert_eq(math::floor(3.7), 3.0)
    assert_eq(math::ceil(3.2), 4.0)
    assert_eq(math::round(3.5), 4.0)

#[test]
fn test_math_min_max():
    assert_eq(math::min(3, 7), 3)
    assert_eq(math::max(3, 7), 7)

#[test]
fn test_math_clamp():
    assert_eq(math::clamp(5, 0, 10), 5)
    assert_eq(math::clamp(-5, 0, 10), 0)
    assert_eq(math::clamp(15, 0, 10), 10)

#[test]
fn test_math_gcd_lcm():
    assert_eq(math::gcd(12, 8), 4)
    assert_eq(math::lcm(4, 6), 12)

#[test]
fn test_math_is_prime():
    assert(math::is_prime(2), "2 is prime")
    assert(math::is_prime(17), "17 is prime")
    assert(not math::is_prime(4), "4 is not prime")
    assert(not math::is_prime(1), "1 is not prime")

#[test]
fn test_math_fibonacci():
    assert_eq(math::fibonacci(0), 0)
    assert_eq(math::fibonacci(1), 1)
    assert_eq(math::fibonacci(10), 55)

#[test]
fn test_math_factorial():
    assert_eq(math::factorial(0), 1)
    assert_eq(math::factorial(5), 120)
    assert_eq(math::factorial(10), 3628800)

#[test]
fn test_math_vec2():
    let a = math::Vec2 { x: 3.0, y: 4.0 }
    assert(math::approx_eq(a.length(), 5.0, 1e-10), "|(3,4)| = 5")

    let b = math::Vec2 { x: 1.0, y: 0.0 }
    assert(math::approx_eq(a.dot(b), 3.0, 1e-10), "(3,4)·(1,0) = 3")

#[test]
fn test_math_mat4_identity():
    let m = math::Mat4::identity()
    assert(math::approx_eq(m.data[0], 1.0, 1e-10), "m[0][0] = 1")
    assert(math::approx_eq(m.data[5], 1.0, 1e-10), "m[1][1] = 1")
    assert(math::approx_eq(m.data[10], 1.0, 1e-10), "m[2][2] = 1")
    assert(math::approx_eq(m.data[15], 1.0, 1e-10), "m[3][3] = 1")

# ============================================================================
# Smart Pointer Tests
# ============================================================================

#[test]
fn test_box():
    let b = Box::new(42)
    assert_eq(*b, 42)

#[test]
fn test_rc():
    let a = Rc::new(42)
    let b = a.clone()
    assert_eq(*a, 42)
    assert_eq(*b, 42)
    assert_eq(a.strong_count(), 2)

#[test]
fn test_arc():
    let a = Arc::new(42)
    let b = a.clone()
    assert_eq(*a, 42)
    assert_eq(a.strong_count(), 2)

#[test]
fn test_refcell():
    let cell = RefCell::new(42)
    {
        let r = cell.borrow()
        assert_eq(*r, 42)
    }
    {
        let mut w = cell.borrow_mut()
        *w = 100
    }
    let r2 = cell.borrow()
    assert_eq(*r2, 100)

# ============================================================================
# Iterator Tests
# ============================================================================

#[test]
fn test_iterator_map():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    let result: Vector<i32> = v.iter().map(|x| x * x).collect()
    assert_eq(result, vec![1, 4, 9])

#[test]
fn test_iterator_filter():
    let mut v = Vector::new()
    for i in 1..=10:
        v.push(i)
    let evens: Vector<i32> = v.iter().filter(|x| x % 2 == 0).collect()
    assert_eq(evens, vec![2, 4, 6, 8, 10])

#[test]
fn test_iterator_fold():
    let mut v = Vector::new()
    v.push(1)
    v.push(2)
    v.push(3)
    let sum = v.iter().fold(0, |acc, x| acc + x)
    assert_eq(sum, 6)

#[test]
fn test_iterator_enumerate():
    let mut v = Vector::new()
    v.push("a")
    v.push("b")
    v.push("c")
    let mut indices = Vector::new()
    for (i, val) in v.iter().enumerate():
        indices.push(i)
    assert_eq(indices, vec![0, 1, 2])

#[test]
fn test_iterator_zip():
    let a = vec![1, 2, 3]
    let b = vec!["a", "b", "c"]
    let pairs: Vector<(i32, &str)> = a.iter().zip(b.iter()).collect()
    assert_eq(pairs.len(), 3)

#[test]
fn test_iterator_chain():
    let a = vec![1, 2]
    let b = vec![3, 4]
    let combined: Vector<i32> = a.iter().chain(b.iter()).collect()
    assert_eq(combined, vec![1, 2, 3, 4])

#[test]
fn test_iterator_take_skip():
    let v = vec![1, 2, 3, 4, 5]
    let first3: Vector<i32> = v.iter().take(3).collect()
    assert_eq(first3, vec![1, 2, 3])

    let skip2: Vector<i32> = v.iter().skip(2).collect()
    assert_eq(skip2, vec![3, 4, 5])

#[test]
fn test_iterator_any_all():
    let v = vec![2, 4, 6, 8]
    assert(v.iter().all(|x| x % 2 == 0), "all even")
    assert(v.iter().any(|x| x > 5), "any > 5")
    assert(not v.iter().any(|x| x > 10), "none > 10")

#[test]
fn test_iterator_find():
    let v = vec![1, 2, 3, 4, 5]
    let found = v.iter().find(|x| x > 3)
    assert_eq(found, Some(&4))

#[test]
fn test_iterator_count():
    let v = vec![1, 2, 3, 4, 5]
    assert_eq(v.iter().count(), 5)
    assert_eq(v.iter().filter(|x| x % 2 == 0).count(), 2)

# ============================================================================
# Path Tests
# ============================================================================

#[test]
fn test_path_components():
    let p = Path::new("/usr/local/bin/omni")
    assert_eq(p.file_name(), Some("omni"))
    assert_eq(p.parent(), Some(Path::new("/usr/local/bin")))
    assert_eq(p.extension(), None)

#[test]
fn test_path_with_extension():
    let p = Path::new("/home/user/file.txt")
    assert_eq(p.extension(), Some("txt"))
    assert_eq(p.file_stem(), Some("file"))

#[test]
fn test_path_join():
    let base = Path::new("/usr/local")
    let full = base.join("bin").join("omni")
    assert_eq(full.to_str(), "/usr/local/bin/omni")

#[test]
fn test_path_is_absolute():
    assert(Path::new("/absolute").is_absolute(), "should be absolute")
    assert(not Path::new("relative").is_absolute(), "should be relative")
