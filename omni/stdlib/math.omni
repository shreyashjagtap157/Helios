module std::math

# ============================================================================
# Omni Standard Library — Mathematics
# ============================================================================
# Constants, trigonometry, exponentials, logarithms, integer utilities.
# Wraps libm / platform math via C FFI.

import std::core::{PartialOrd, Ord, Ordering, PartialEq, Clone, Display, Debug}

# ============================================================================
# Constants
# ============================================================================

const PI: f64 = 3.14159265358979323846
const TAU: f64 = 6.28318530717958647692
const E: f64 = 2.71828182845904523536
const LN_2: f64 = 0.69314718055994530942
const LN_10: f64 = 2.30258509299404568402
const LOG2_E: f64 = 1.44269504088896340736
const LOG10_E: f64 = 0.43429448190325182765
const SQRT_2: f64 = 1.41421356237309504880
const FRAC_1_PI: f64 = 0.31830988618379067154
const FRAC_2_PI: f64 = 0.63661977236758134308
const FRAC_PI_2: f64 = 1.57079632679489661923
const FRAC_PI_3: f64 = 1.04719755119659774615
const FRAC_PI_4: f64 = 0.78539816339744830962
const FRAC_PI_6: f64 = 0.52359877559829887308

const F64_EPSILON: f64 = 2.2204460492503131e-16
const F64_MIN: f64 = 2.2250738585072014e-308
const F64_MAX: f64 = 1.7976931348623158e+308
const F64_INFINITY: f64 = 1.0 / 0.0
const F64_NEG_INFINITY: f64 = -1.0 / 0.0
const F64_NAN: f64 = 0.0 / 0.0

const F32_EPSILON: f32 = 1.1920929e-7
const F32_MIN: f32 = 1.1754944e-38
const F32_MAX: f32 = 3.4028235e+38

const I8_MIN: i8 = -128
const I8_MAX: i8 = 127
const U8_MAX: u8 = 255
const I16_MIN: i16 = -32768
const I16_MAX: i16 = 32767
const U16_MAX: u16 = 65535
const I32_MIN: i32 = -2147483648
const I32_MAX: i32 = 2147483647
const U32_MAX: u32 = 4294967295
const I64_MIN: i64 = -9223372036854775808
const I64_MAX: i64 = 9223372036854775807
const U64_MAX: u64 = 18446744073709551615
const USIZE_MAX: usize = 18446744073709551615

