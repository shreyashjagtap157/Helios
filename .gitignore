# =============================================================================
# Helios / Omni Project .gitignore
# =============================================================================

# --- Rust Build Artifacts ---
target/
target_alt/
**/target_alt/
*.rlib
*.rmeta
Cargo.lock

# --- Compiled Binaries & Build Outputs ---
build/
dist/
out/
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# --- OVM Bytecode (generated, not source) ---
*.ovm
*.ovm.hints

# --- GitNexus / Claude / Memory ---
.gitnexus/
.claude/
Memory/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS-specific ---
Thumbs.db
.DS_Store
desktop.ini

# --- Temporary ---
tmp/
.tmp/
*.tmp
*.bak
*.log

# --- Python ---
__pycache__/
*.py[cod]

# --- Node/npm (for vscode-omni tool) ---
node_modules/
package-lock.json

# --- Deployment Scripts ---
*.ps1

# --- Claude Local Overrides ---
CLAUDE.local.md
CLAUDE.md

# =============================================================================
# Un-ignore project source (force-track these)
# =============================================================================
!omni-lang/**/*.rs
!omni-lang/**/*.toml
!omni-lang/**/*.omni
!omni-lang/**/*.bnf
!helios-framework/**/*
!examples/**/*
!.github/**/*
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!ISSUES.md
