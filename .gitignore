# Exclude markdown files except README, Claude, docs, and status reports
*.md
!README.md
!Claude.md
!docs/*.md
!IMPLEMENTATION_STATUS_REPORT.md

# Exclude deployment scripts
*.ps1

# Legacy archives (too large for git)
legacy/*.zip
.gitnexus

# Claude local overrides (must stay personal)
CLAUDE.local.md
.claude/settings.local.json

# Keep Claude control-center committed
!CLAUDE.md
!.claude/
!.claude/**
