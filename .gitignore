# =============================================================================
# Helios / Omni Project .gitignore
# =============================================================================

# --- Rust Build Artifacts ---
target/
*.rlib
*.rmeta
Cargo.lock

# --- Compiled Binaries & Build Outputs ---
build/
dist/
out/
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# --- OVM Bytecode (generated, not source) ---
*.ovm
*.ovm.hints

# --- Obsidian Vault (Memory vault - personal notes, not project code) ---
Memory/

# --- Legacy Archives ---
legacy/
legacy-deprecated/

# --- GitNexus Index ---
.gitnexus/

# --- Temporary Build Directories ---
.tmp-*/
tmp/
.tmp/
*.tmp
*.bak
*.log

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS-specific ---
Thumbs.db
.DS_Store
desktop.ini

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.env
venv/

# --- Node/npm (for vscode-omni tool) ---
node_modules/
package-lock.json

# --- Test Outputs & Reports ---
test_output/
test_results/
coverage/
.coverage
*.profdata
check_output*.txt
test_report.html

# --- Deployment Scripts ---
*.ps1

# --- Old wrapper binary ---
helios-wrapper/

# --- Claude Local Overrides ---
CLAUDE.local.md

# --- Old docs removed in cleanup ---
AGENTS.md
CHANGELOG.md
CONTRIBUTING.md
ISSUES.md
nul

# =============================================================================
# Un-ignore specific tracked files
# =============================================================================
!omni-lang/**/*.rs
!omni-lang/**/*.toml
!omni-lang/**/*.omni
!omni-lang/**/*.bnf
!helios-framework/**/*
!examples/**/*
!config/**/*

!docs/**/*.md
!docs/**/*.bnf
!README.md
!CLAUDE.md
!AUDIT.md

!.claude/
!.claude/**
.claude/settings.local.json
