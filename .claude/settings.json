{
    "project": {
        "name": "Helios",
        "description": "Helios + Omni repository with deterministic language/compiler/runtime and vault-driven documentation workflows",
        "primaryDocs": [
            "AGENTS.md",
            "CLAUDE.md",
            "docs/HELIOS & Omni Language — Comprehensive.md",
            "docs/IMPLEMENTATION_STATUS_REPORT.md"
        ]
    },
    "permissions": {
        "allow": [
            "read_file",
            "list_dir",
            "file_search",
            "grep_search",
            "semantic_search",
            "apply_patch",
            "create_file",
            "create_directory",
            "get_errors",
            "get_changed_files"
        ],
        "deny": [
            "git commit",
            "git push",
            "rm -rf /",
            "destructive-delete-without-confirmation"
        ]
    },
    "defaults": {
        "preferBuiltInTools": true,
        "requireWorkspaceLinksInNotes": true,
        "respectVaultPolicy": true,
        "avoidUnrelatedRefactors": true
    },
    "qualityGates": {
        "documentation": {
            "requireTraceableSourceLinks": true,
            "requireConsistentSectioning": true
        },
        "codeChanges": {
            "preferSmallFocusedPatches": true,
            "verifyErrorsAfterEdits": true
        }
    }
}