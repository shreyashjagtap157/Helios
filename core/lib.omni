# Vector (dynamic array)
struct Vec<T>:
    data: own [T]
    len: usize
    capacity: usize
    
    fn new() -> own Vec<T>:
        return Vec { data: [], len: 0, capacity: 0 }
    
    fn with_capacity(cap: usize) -> own Vec<T>:
        return Vec { data: alloc(cap), len: 0, capacity: cap }
    
    fn push(&mut self, item: T):
        if self.len >= self.capacity:
            self.grow()
        self.data[self.len] = item
        self.len += 1
    
    fn pop(&mut self) -> Option<T>:
        if self.len == 0:
            return None
        self.len -= 1
        return Some(self.data[self.len])
    
    fn get(&self, index: usize) -> Option<&T>:
        if index >= self.len:
            return None
        return Some(&self.data[index])
    
    fn len(&self) -> usize:
        return self.len
    
    fn is_empty(&self) -> bool:
        return self.len == 0
    
    fn iter(&self) -> impl Iterator<&T>:
        return VecIterator { vec: self, index: 0 }

# HashMap
struct HashMap<K, V>:
    buckets: Vec<Vec<(K, V)>>
    len: usize
    
    fn new() -> own HashMap<K, V>:
        let buckets = Vec::with_capacity(16)
        for _ in 0..16:
            buckets.push(Vec::new())
        return HashMap { buckets, len: 0 }
    
    fn insert(&mut self, key: K, value: V) -> Option<V>:
        let hash = key.hash() % self.buckets.len()
        let bucket = &mut self.buckets[hash]
        
        for (k, v) in bucket.iter_mut():
            if k == &key:
                let old = *v
                *v = value
                return Some(old)
        
        bucket.push((key, value))
        self.len += 1
        return None
    
    fn get(&self, key: &K) -> Option<&V>:
        let hash = key.hash() % self.buckets.len()
        let bucket = &self.buckets[hash]
        
        for (k, v) in bucket.iter():
            if k == key:
                return Some(v)
        return None
    
    fn contains_key(&self, key: &K) -> bool:
        return self.get(key).is_some()
    
    fn len(&self) -> usize:
        return self.len

# HashSet
struct HashSet<T>:
    map: HashMap<T, ()>
    
    fn new() -> own HashSet<T>:
        return HashSet { map: HashMap::new() }
    
    fn insert(&mut self, value: T) -> bool:
        return self.map.insert(value, ()).is_none()
    
    fn contains(&self, value: &T) -> bool:
        return self.map.contains_key(value)
    
    fn len(&self) -> usize:
        return self.map.len()

# Formatting
fn format(template: &str, args: ...) -> String:
    # Format string with arguments
    ...

fn println(msg: &str):
    system::stdout::write_line(msg)

fn print(msg: &str):
    system::stdout::write(msg)

fn panic(msg: &str):
    system::stderr::write_line(&format!("PANIC: {}", msg))
    system::exit(1)
