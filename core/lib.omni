# HELIOS Standard Library - Core Module
# Written in Omni

module core

# Re-export common modules
pub use logging
pub use json
pub use math

# Basic traits
trait Display:
    fn to_string(&self) -> String

trait Debug:
    fn debug_string(&self) -> String

trait Clone:
    fn clone(&self) -> own Self

trait Default:
    fn default() -> own Self

trait Eq:
    fn eq(&self, other: &Self) -> bool
    fn ne(&self, other: &Self) -> bool:
        return !self.eq(other)

trait Ord:
    fn cmp(&self, other: &Self) -> Ordering
    fn lt(&self, other: &Self) -> bool
    fn gt(&self, other: &Self) -> bool
    fn le(&self, other: &Self) -> bool
    fn ge(&self, other: &Self) -> bool

enum Ordering:
    Less
    Equal
    Greater

# Option type
enum Option<T>:
    Some(value: T)
    None
    
    fn is_some(&self) -> bool:
        match self:
            Some(_): true
            None: false
    
    fn is_none(&self) -> bool:
        return !self.is_some()
    
    fn unwrap(&self) -> &T:
        match self:
            Some(v): v
            None: panic("unwrap on None")
    
    fn unwrap_or(&self, default: T) -> T:
        match self:
            Some(v): v
            None: default
    
    fn map<U>(&self, f: fn(&T) -> U) -> Option<U>:
        match self:
            Some(v): Some(f(v))
            None: None

# Result type for error handling
enum Result<T, E>:
    Ok(value: T)
    Err(error: E)
    
    fn is_ok(&self) -> bool:
        match self:
            Ok(_): true
            Err(_): false
    
    fn is_err(&self) -> bool:
        return !self.is_ok()
    
    fn unwrap(&self) -> &T:
        match self:
            Ok(v): v
            Err(e): panic("unwrap on Err: {:?}", e)
    
    fn unwrap_err(&self) -> &E:
        match self:
            Ok(_): panic("unwrap_err on Ok")
            Err(e): e
    
    fn map<U>(&self, f: fn(&T) -> U) -> Result<U, E>:
        match self:
            Ok(v): Ok(f(v))
            Err(e): Err(e)
    
    fn map_err<F>(&self, f: fn(&E) -> F) -> Result<T, F>:
        match self:
            Ok(v): Ok(v)
            Err(e): Err(f(e))

