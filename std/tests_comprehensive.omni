# ============================================================================
# CORE TESTS
# ============================================================================

#[test]
fn test_primitive_types():
    let i: i8 = -128
    let u: u64 = 18446744073709551615u64
    let f: f64 = 3.14159
    let b: bool = true
    let c: char = 'A'
    
    assert_eq!(i, -128i8)
    assert_eq!(u, 18446744073709551615u64)
    assert!(f > 3.0)
    assert!(b)
    assert_eq!(c, 'A')

#[test]
fn test_string_operations():
    let s = "Hello, World!"
    let len = s.len()
    let upper = s.to_uppercase()
    let lower = s.to_lowercase()
    
    assert_eq!(len, 13)
    assert!(upper.contains("HELLO"))
    assert!(lower.contains("world"))
    
    let parts: Vec<str> = s.split(",").collect()
    assert_eq!(parts.len(), 2)

#[test]
fn test_option_and_result():
    let some_val: Option<i32> = Some(42)
    let none_val: Option<i32> = None
    
    assert!(some_val.is_some())
    assert!(none_val.is_none())
    assert_eq!(some_val.unwrap_or(0), 42)
    assert_eq!(none_val.unwrap_or(0), 0)
    
    let ok_val: Result<String, str> = Ok("success".to_string())
    let err_val: Result<String, str> = Err("failure")
    
    assert!(ok_val.is_ok())
    assert!(err_val.is_err())

# ============================================================================
# COLLECTIONS TESTS
# ============================================================================

#[test]
fn test_vector_operations():
    var vec = Vec::new()
    vec.push(1)
    vec.push(2)
    vec.push(3)
    
    assert_eq!(vec.len(), 3)
    assert_eq!(vec[0], 1)
    assert_eq!(vec.pop(), Some(3))
    
    vec.clear()
    assert!(vec.is_empty())

#[test]
fn test_hashmap_operations():
    var map = HashMap::new()
    map.insert("key1", "value1")
    map.insert("key2", "value2")
    
    assert_eq!(map.len(), 2)
    assert_eq!(map.get("key1"), Some(&"value1"))
    
    let removed = map.remove("key1")
    assert_eq!(removed, Some("value1"))
    assert_eq!(map.len(), 1)

#[test]
fn test_hashset_operations():
    var set = HashSet::new()
    set.insert(1)
    set.insert(2)
    set.insert(3)
    
    assert_eq!(set.len(), 3)
    assert!(set.contains(&1))
    
    set.remove(&2)
    assert!(!set.contains(&2))

#[test]
fn test_btree_map():
    var map = BTreeMap::new()
    map.insert(3, "three")
    map.insert(1, "one")
    map.insert(2, "two")
    
    assert_eq!(map.len(), 3)
    
    # BTreeMap maintains sorted order
    let keys: Vec<i32> = map.keys().collect()
    assert_eq!(keys, vec![1, 2, 3])

# ============================================================================
# I/O TESTS
# ============================================================================

#[test]
fn test_file_operations():
    # Create test file
    let test_file = "test_output.txt"
    let content = "Hello, File System!"
    
    fs::write_string(test_file, content)
        .expect("Failed to write file")
    
    let read_content = fs::read_string(test_file)
        .expect("Failed to read file")
    
    assert_eq!(read_content, content)
    
    # Cleanup
    fs::delete(test_file).expect("Failed to delete file")

#[test]
fn test_path_operations():
    let path = Path::new("/home/user/project/src/main.omni")
    
    assert_eq!(path.file_name(), Some("main.omni"))
    assert_eq!(path.extension(), Some("omni"))
    assert!(path.is_absolute())

# ============================================================================
# CONCURRENCY TESTS
# ============================================================================

#[test]
fn test_thread_basic():
    let handle = thread::spawn(|| {
        return 42
    })
    
    let result = handle.join().expect("Thread panicked")
    assert_eq!(result, 42)

#[test]
fn test_mutex():
    let mut counter = Mutex::new(0)
    
    {
        let mut guard = counter.lock()
        *guard = 10
    }  # Lock released here
    
    let final_val = *counter.lock()
    assert_eq!(final_val, 10)

#[test]
fn test_channel_mpsc():
    let (sender, receiver) = mpsc::channel()
    
    sender.send(42).expect("Failed to send")
    let received = receiver.recv().expect("Failed to receive")
    
    assert_eq!(received, 42)

# ============================================================================
# ASYNC TESTS
# ============================================================================

#[test]
fn test_future_basic():
    let future_val = async {
        return 100
    }
    
    let result = block_on(future_val)
    assert_eq!(result, 100)

#[test]
fn test_timer():
    let start = time::now()
    
    let future_val = async {
        time::sleep(time::Duration::from_millis(100)).await
        return "done"
    }
    
    let _result = block_on(future_val)
    let elapsed = time::now().duration_since(start)
    
    assert!(elapsed.as_millis() >= 100)

# ============================================================================
# CRYPTOGRAPHY TESTS (SECURITY-CRITICAL)
# ============================================================================

#[test]
fn test_sha256_basic():
    let data = "The quick brown fox jumps over the lazy dog"
    let hash = crypto::sha256(data.as_bytes())
    
    # Known correct SHA-256 hash
    let expected = "d7a8fbb307d7809469ca9abdcbed1b82814049252c6f058d8dd13823e63fbef08"
    assert_eq!(hash.to_hex(), expected)

#[test]
fn test_sha256_empty():
    let hash = crypto::sha256(&[])
    let expected = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    assert_eq!(hash.to_hex(), expected)

#[test]
fn test_aes256_encrypt_decrypt():
    let key = crypto::rand_bytes(32)
    let plaintext = "Secret message"
    let nonce = crypto::rand_bytes(16)
    
    let ciphertext = crypto::aes256_encrypt(plaintext.as_bytes(), &key, &nonce)
    let decrypted = crypto::aes256_decrypt(&ciphertext, &key, &nonce)
        .expect("Decryption failed")
    
    assert_eq!(String::from_utf8(decrypted).unwrap(), plaintext)

#[test]
fn test_hmac_sha256():
    let key = "secret_key"
    let message = "message to authenticate"
    
    let hmac1 = crypto::hmac_sha256(message.as_bytes(), key.as_bytes())
    let hmac2 = crypto::hmac_sha256(message.as_bytes(), key.as_bytes())
    
    # HMACs should be deterministic
    assert_eq!(hmac1, hmac2)

#[test]
fn test_rsa_basic():
    let (public_key, private_key) = crypto::rsa_generate_keypair(2048)
    
    let plaintext = "Hello, RSA!"
    let ciphertext = crypto::rsa_encrypt(plaintext.as_bytes(), &public_key)
        .expect("Encryption failed")
    
    let decrypted = crypto::rsa_decrypt(&ciphertext, &private_key)
        .expect("Decryption failed")
    
    assert_eq!(String::from_utf8(decrypted).unwrap(), plaintext)

#[test]
fn test_random_bytes():
    let bytes1 = crypto::rand_bytes(32)
    let bytes2 = crypto::rand_bytes(32)
    
    # Random bytes should (almost certainly) be different
    assert_ne!(bytes1, bytes2)
    assert_eq!(bytes1.len(), 32)

# ============================================================================
# TENSOR TESTS
# ============================================================================

#[test]
fn test_tensor_creation():
    let shape = vec![3, 4]
    let mut tensor = Tensor::zeros(shape)
    
    assert_eq!(tensor.shape(), vec![3, 4])
    assert_eq!(tensor.size(), 12)

#[test]
fn test_tensor_operations():
    let mut t1 = Tensor::ones(vec![2, 2])
    let t2 = Tensor::ones(vec![2, 2])
    
    # Element-wise operations
    let sum = t1.add(&t2)
    assert_eq!(sum.get(&vec![0, 0]), 2.0)
    
    let prod = t1.mul(&t2)
    assert_eq!(prod.get(&vec![0, 0]), 1.0)

#[test]
fn test_tensor_reshape():
    let tensor = Tensor::ones(vec![6])
    let reshaped = tensor.reshape(vec![2, 3])
    
    assert_eq!(reshaped.shape(), vec![2, 3])
    assert_eq!(reshaped.size(), 6)

# ============================================================================
# IMAGE TESTS
# ============================================================================

#[test]
fn test_image_load():
    # Create a simple test image
    let img = Image::new(10, 10, ColorSpace::RGB)
    
    assert_eq!(img.width(), 10)
    assert_eq!(img.height(), 10)

#[test]
fn test_image_filtering():
    let img = Image::new(10, 10, ColorSpace::RGB)
    
    # Apply simple filters
    let blurred = img.blur(3)
    assert_eq!(blurred.width(), 10)
    
    let edges = img.edge_detect()
    assert_eq!(edges.width(), 10)

# ============================================================================
# REGEX TESTS
# ============================================================================

#[test]
fn test_regex_match():
    let pattern = "a+b*"
    let regex = Regex::new(pattern).expect("Invalid regex")
    
    assert!(regex.is_match("aaa"))
    assert!(regex.is_match("aaaabbbb"))
    assert!(!regex.is_match("bbb"))

#[test]
fn test_regex_capture():
    let pattern = r"(\w+)=(\d+)"
    let regex = Regex::new(pattern).expect("Invalid regex")
    
    let text = "count=42"
    let captures = regex.captures(text)
    
    assert!(captures.is_some())

# ============================================================================
# COMPRESSION TESTS
# ============================================================================

#[test]
fn test_gzip_compression():
    let original = b"This is a test string that will be compressed using gzip"
    let compressed = compress::gzip(original)
    let decompressed = compress::ungzip(&compressed)
        .expect("Decompression failed")
    
    assert_eq!(original, &decompressed[..])

#[test]
fn test_zstd_compression():
    let original = b"Zstandard compression test data"
    let compressed = compress::zstd(original)
    let decompressed = compress::unzstd(&compressed)
        .expect("Decompression failed")
    
    assert_eq!(original, &decompressed[..])

# ============================================================================
# JSON TESTS
# ============================================================================

#[test]
fn test_json_parse():
    let json_str = r#"{"name": "Alice", "age": 30}"#
    let value = json::parse(json_str).expect("Failed to parse JSON")
    
    assert_eq!(value.get("name").unwrap().as_string(), "Alice")
    assert_eq!(value.get("age").unwrap().as_i64(), 30)

#[test]
fn test_json_serialize():
    var obj = json::Object::new()
    obj.insert("x", json::Number(42.0))
    obj.insert("y", json::Number(3.14))
    
    let serialized = json::stringify(&obj)
    let reparsed = json::parse(&serialized)
        .expect("Failed to reparse")
    
    assert_eq!(reparsed.get("x").unwrap().as_f64(), 42.0)

# ============================================================================
# MATH TESTS
# ============================================================================

#[test]
fn test_trigonometry():
    assert!((math::sin(0.0) - 0.0).abs() < 0.0001)
    assert!((math::cos(0.0) - 1.0).abs() < 0.0001)
    assert!((math::sin(math::PI / 2.0) - 1.0).abs() < 0.0001)

#[test]
fn test_logarithms():
    assert!((math::ln(math::E) - 1.0).abs() < 0.0001)
    assert!((math::log10(100.0) - 2.0).abs() < 0.0001)

#[test]
fn test_vector_math():
    let v1 = Vec3::new(1.0, 2.0, 3.0)
    let v2 = Vec3::new(4.0, 5.0, 6.0)
    
    let dot = v1.dot(&v2)
    assert_eq!(dot, 32.0)  # 1*4 + 2*5 + 3*6
    
    let cross = v1.cross(&v2)
    assert_eq!(cross.x, -3.0)
    assert_eq!(cross.y, 6.0)
    assert_eq!(cross.z, -3.0)

#[test]
fn test_matrix_multiplication():
    let m1 = Mat4::identity()
    let m2 = Mat4::identity()
    
    let result = m1.mul(&m2)
    assert!(result.is_identity())

# ============================================================================
# NETWORKING TESTS
# ============================================================================

#[test]
fn test_ip_address():
    let ip4 = IpAddr::V4("127.0.0.1")
    assert!(ip4.is_loopback())
    
    let ip6 = IpAddr::V6("::1")
    assert!(ip6.is_loopback())

#[test]
fn test_socket_addr():
    let addr = SocketAddr::new(IpAddr::V4("127.0.0.1"), 8080)
    assert_eq!(addr.port(), 8080)

# ============================================================================
# SERIALIZATION TESTS
# ============================================================================

#[test]
fn test_serde_roundtrip():
    struct TestData:
        name: String
        value: i32
    
    let original = TestData {
        name: "test",
        value: 42,
    }
    
    let serialized = serde::serialize(&original)
    let deserialized: TestData = serde::deserialize(&serialized)
    
    assert_eq!(deserialized.name, "test")
    assert_eq!(deserialized.value, 42)

# ============================================================================
# ALGORITHM TESTS
# ============================================================================

#[test]
fn test_sorting():
    var arr = vec![5, 2, 8, 1, 9]
    algorithm::sort(&mut arr)
    assert_eq!(arr, vec![1, 2, 5, 8, 9])

#[test]
fn test_binary_search():
    let arr = vec![1, 2, 5, 8, 9]
    let idx = algorithm::binary_search(&arr, 5)
    assert_eq!(idx, Some(2))

# ============================================================================
# TIME & BENCHMARKING TESTS
# ============================================================================

#[test]
fn test_duration():
    let d1 = time::Duration::from_millis(1000)
    let d2 = time::Duration::from_secs(1)
    
    assert_eq!(d1, d2)

#[test]
fn test_benchmark():
    let result = benchmarks::measure(|| {
        let mut sum = 0
        for i in 0..1000:
            sum += i
        return sum
    })
    
    assert!(result.iterations > 0)

# ============================================================================
# DISTRIBUTED TESTS
# ============================================================================

#[test]
fn test_rpc_serialization():
    struct Message:
        id: u32
        payload: String
    
    let msg = Message { id: 1, payload: "test" }
    let encoded = dist::encode(&msg)
    let decoded: Message = dist::decode(&encoded)
    
    assert_eq!(decoded.id, 1)
    assert_eq!(decoded.payload, "test")

# ============================================================================
# MEMORY TESTS
# ============================================================================

#[test]
fn test_allocator():
    let alloc = mem::GlobalAllocator::default()
    let ptr = alloc.allocate(1024)
    
    assert!(!ptr.is_null())
    
    alloc.deallocate(ptr, 1024)

# ============================================================================
# REFLECTION TESTS
# ============================================================================

#[test]
fn test_type_info():
    let info = reflect::type_of::<Vec<i32>>()
    
    assert!(info.name.contains("Vec"))

#[test]
fn test_field_access():
    struct Point:
        x: f64
        y: f64
    
    let p = Point { x: 3.0, y: 4.0 }
    let x_value = reflect::get_field(&p, "x")
    
    assert_eq!(x_value, 3.0)
