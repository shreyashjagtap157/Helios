# HELIOS Configuration Types and Loader
# Load and validate configuration from TOML

module config::loader

import core::logging as log
import core::toml
import system::fs

struct HeliosConfig:
    model: ModelConfig
    training: TrainingConfig
    inference: InferenceConfig
    data: DataConfig
    web_learning: WebLearningConfig
    safety: SafetyConfig
    biometrics: BiometricsConfig
    system: SystemConfig
    logging: LoggingConfig
    hot_swap: HotSwapConfig
    
    # Advanced Optimizations
    tang_sampling: TangConfig
    pruning: PruningConfig
    infini_attention: InfiniConfig
    air_llm: AirLLMConfig
    recursive_memory: RecursiveConfig
    continuous_learning: ContinuousLearningConfig


struct ModelConfig:
    name: String
    knowledge_capacity: usize
    max_reasoning_depth: usize
    max_context_length: usize
    confidence_threshold: f32
    activation: String
    checkpoint_path: String
    tokenizer_path: String
    
    fn default() -> own ModelConfig:
        return ModelConfig {
            name: "helios-base".to_string(),
            knowledge_capacity: 1000000,
            max_reasoning_depth: 10,
            max_context_length: 8192,
            confidence_threshold: 0.5,
            activation: "cognitive".to_string(),
            checkpoint_path: "checkpoints/latest".to_string(),
            tokenizer_path: "tokenizer".to_string()
        }


struct TrainingConfig:
    enabled: bool
    data_path: String
    checkpoint_dir: String
    consolidation_rate: f32
    min_confidence: f32
    pruning_threshold: f32
    max_memory_gb: usize
    warmup_steps: usize
    max_steps: usize
    ingestion_chunk_size: usize
    knowledge_consolidation_interval: usize
    checkpoint_interval_steps: usize
    log_interval: usize
    eval_interval: usize
    
    fn default() -> own TrainingConfig:
        return TrainingConfig {
            enabled: true,
            data_path: "data/knowledge".to_string(),
            checkpoint_dir: "checkpoints".to_string(),
            consolidation_rate: 0.8,
            min_confidence: 0.3,
            pruning_threshold: 0.1,
            max_memory_gb: 8,
            warmup_steps: 100,
            max_steps: 1000000,
            ingestion_chunk_size: 64,
            knowledge_consolidation_interval: 500,
            checkpoint_interval_steps: 5000,
            log_interval: 100,
            eval_interval: 1000
        }


struct InferenceConfig:
    max_reasoning_steps: usize
    confidence_threshold: f32
    exploration_factor: f32
    max_hypotheses: usize
    analogy_weight: f32
    enable_caching: bool
    
    fn default() -> own InferenceConfig:
        return InferenceConfig {
            max_reasoning_steps: 50,
            confidence_threshold: 0.6,
            exploration_factor: 0.3,
            max_hypotheses: 10,
            analogy_weight: 0.4,
            enable_caching: true
        }


struct DataConfig:
    shuffle_buffer_size: usize
    num_workers: usize
    prefetch_batches: usize
    cache_dir: String
    
    fn default() -> own DataConfig:
        return DataConfig {
            shuffle_buffer_size: 10000,
            num_workers: 4,
            prefetch_batches: 2,
            cache_dir: "cache/data".to_string()
        }


struct WebLearningConfig:
    enabled: bool
    max_results_per_query: usize
    rate_limit_ms: usize
    max_crawl_depth: usize
    cache_dir: String
    search_engines: Vec<String>
    blocked_domains: Vec<String>
    dream_state_enabled: bool
    min_idle_time_minutes: usize
    cycle_interval_minutes: usize
    
    fn default() -> own WebLearningConfig:
        return WebLearningConfig {
            enabled: true,
            max_results_per_query: 10,
            rate_limit_ms: 1000,
            max_crawl_depth: 2,
            cache_dir: "cache/web".to_string(),
            search_engines: vec!["duckduckgo".to_string(), "wikipedia".to_string()],
            blocked_domains: vec![],
            dream_state_enabled: true,
            min_idle_time_minutes: 5,
            cycle_interval_minutes: 30
        }


struct SafetyConfig:
    enabled: bool
    strict_mode: bool
    log_all_actions: bool
    require_verification: bool
    verification_timeout_minutes: usize
    protected_modules: Vec<String>
    
    fn default() -> own SafetyConfig:
        return SafetyConfig {
            enabled: true,
            strict_mode: true,
            log_all_actions: true,
            require_verification: true,
            verification_timeout_minutes: 30,
            protected_modules: vec![
                "safety::asimov".to_string(),
                "core::lib".to_string()
            ]
        }


struct BiometricsConfig:
    enabled: bool
    enrollment_time_minutes: usize
    min_keystroke_samples: usize
    verification_window_seconds: usize
    similarity_threshold: f32
    
    fn default() -> own BiometricsConfig:
        return BiometricsConfig {
            enabled: true,
            enrollment_time_minutes: 30,
            min_keystroke_samples: 1000,
            verification_window_seconds: 60,
            similarity_threshold: 0.7
        }


struct SystemConfig:
    cuda_enabled: bool
    cuda_device: usize
    memory_limit_gb: usize
    cpu_threads: usize
    
    fn default() -> own SystemConfig:
        return SystemConfig {
            cuda_enabled: true,
            cuda_device: 0,
            memory_limit_gb: 32,
            cpu_threads: 8
        }


struct LoggingConfig:
    level: String
    file: String
    max_file_size_mb: usize
    max_files: usize
    format: String
    
    fn default() -> own LoggingConfig:
        return LoggingConfig {
            level: "info".to_string(),
            file: "logs/helios.log".to_string(),
            max_file_size_mb: 100,
            max_files: 10,
            format: "text".to_string()
        }


struct HotSwapConfig:
    enabled: bool
    sandbox_timeout_ms: usize
    backup_enabled: bool
    backup_dir: String
    
    fn default() -> own HotSwapConfig:
        return HotSwapConfig {
            enabled: true,
            sandbox_timeout_ms: 5000,
            backup_enabled: true,
            backup_dir: "backups/modules".to_string()
        }


impl HeliosConfig:
    fn default() -> own HeliosConfig:
        return HeliosConfig {
            model: ModelConfig::default(),
            training: TrainingConfig::default(),
            inference: InferenceConfig::default(),
            data: DataConfig::default(),
            web_learning: WebLearningConfig::default(),
            safety: SafetyConfig::default(),
            biometrics: BiometricsConfig::default(),
            system: SystemConfig::default(),
            logging: LoggingConfig::default(),
            hot_swap: HotSwapConfig::default(),
            tang_sampling: TangConfig::default(),
            pruning: PruningConfig::default(),
            infini_attention: InfiniConfig::default(),
            air_llm: AirLLMConfig::default(),
            recursive_memory: RecursiveConfig::default(),
            continuous_learning: ContinuousLearningConfig::default()
        }


struct TangConfig:
    enabled: bool
    sample_rate: usize
    
    fn default() -> own TangConfig:
        TangConfig { enabled: false, sample_rate: 100 }


struct PruningConfig:
    enabled: bool
    target_sparsity: f32
    method: String
    
    fn default() -> own PruningConfig:
        PruningConfig { enabled: false, target_sparsity: 0.9, method: "block_influence".to_string() }


struct InfiniConfig:
    enabled: bool
    segment_length: usize
    memory_dim: usize
    
    fn default() -> own InfiniConfig:
        InfiniConfig { enabled: false, segment_length: 2048, memory_dim: 256 }


struct AirLLMConfig:
    enabled: bool
    chunk_size_mb: usize
    
    fn default() -> own AirLLMConfig:
        AirLLMConfig { enabled: false, chunk_size_mb: 1024 }


struct RecursiveConfig:
    enabled: bool
    max_depth: usize
    
    fn default() -> own RecursiveConfig:
        RecursiveConfig { enabled: false, max_depth: 3 }


struct ContinuousLearningConfig:
    enabled: bool
    confidence_threshold: f32
    update_frequency: usize
    
    fn default() -> own ContinuousLearningConfig:
        ContinuousLearningConfig { enabled: false, confidence_threshold: 0.8, update_frequency: 1000 }


fn load(path: &str) -> Result<HeliosConfig, ConfigError>:
    log::info("Loading configuration from {}", path)
    
    if !fs::exists(path):
        log::warn("Config file not found, using defaults")
        return Ok(HeliosConfig::default())
    
    let content = fs::read_string(path)?
    let doc = toml::parse(&content)?
    
    let mut config = HeliosConfig::default()
    
    # Parse model section
    if let Some(model) = doc.get("model"):
        if let Some(name) = model.get("name").and_then(|v| v.as_str()):
            config.model.name = name.to_string()
    # Parse model section
    if let Some(model) = doc.get("model"):
        if let Some(name) = model.get("name").and_then(|v| v.as_str()):
            config.model.name = name.to_string()
        if let Some(kc) = model.get("knowledge_capacity").and_then(|v| v.as_int()):
            config.model.knowledge_capacity = kc as usize
        if let Some(rd) = model.get("max_reasoning_depth").and_then(|v| v.as_int()):
            config.model.max_reasoning_depth = rd as usize
        if let Some(cl) = model.get("max_context_length").and_then(|v| v.as_int()):
            config.model.max_context_length = cl as usize
        if let Some(ct) = model.get("confidence_threshold").and_then(|v| v.as_float()):
            config.model.confidence_threshold = ct as f32
    
    # Parse training section
    if let Some(training) = doc.get("training"):
        if let Some(cr) = training.get("consolidation_rate").and_then(|v| v.as_float()):
            config.training.consolidation_rate = cr as f32
        if let Some(cs) = training.get("ingestion_chunk_size").and_then(|v| v.as_int()):
            config.training.ingestion_chunk_size = cs as usize
        if let Some(ws) = training.get("warmup_steps").and_then(|v| v.as_int()):
            config.training.warmup_steps = ws as usize
        if let Some(ms) = training.get("max_steps").and_then(|v| v.as_int()):
            config.training.max_steps = ms as usize
    
    # Parse inference section
    if let Some(inference) = doc.get("inference"):
        if let Some(ct) = inference.get("confidence_threshold").and_then(|v| v.as_float()):
            config.inference.confidence_threshold = ct as f32
        if let Some(ef) = inference.get("exploration_factor").and_then(|v| v.as_float()):
            config.inference.exploration_factor = ef as f32
        if let Some(mh) = inference.get("max_hypotheses").and_then(|v| v.as_int()):
            config.inference.max_hypotheses = mh as usize
    
    # Parse safety section
    if let Some(safety) = doc.get("safety"):
        if let Some(e) = safety.get("enabled").and_then(|v| v.as_bool()):
            config.safety.enabled = e
        if let Some(sm) = safety.get("strict_mode").and_then(|v| v.as_bool()):
            config.safety.strict_mode = sm
    
    log::info("Configuration loaded successfully")
    return Ok(config)


enum ConfigError:
    FileNotFound(path: String)
    ParseError(message: String)
    ValidationError(message: String)
