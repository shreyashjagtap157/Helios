{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "<",
            ">"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "<",
            "close": ">",
            "notIn": [
                "string"
            ]
        },
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string"
            ]
        },
        {
            "open": "'",
            "close": "'",
            "notIn": [
                "string",
                "comment"
            ]
        }
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "<",
            ">"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(fn|struct|enum|trait|impl|if|for|while|match|module)\\b",
            "end": "^\\s*$"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(fn|struct|enum|trait|impl|if|elif|else|for|while|match|try|except)\\b.*:\\s*$",
        "decreaseIndentPattern": "^\\s*(elif|else|except)\\b"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(fn|struct|enum|trait|impl|if|elif|else|for|while|match|try|except)\\b.*:\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}