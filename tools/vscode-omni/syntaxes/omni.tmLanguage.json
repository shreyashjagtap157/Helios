{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Omni",
    "scopeName": "source.omni",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#functions" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#attributes" },
        { "include": "#numbers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.omni",
                    "match": "#.*$"
                },
                {
                    "name": "comment.block.documentation.omni",
                    "begin": "\"\"\"",
                    "end": "\"\"\""
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.omni",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.omni",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.embedded.line.omni",
                            "match": "\\{[^}]*\\}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.omni",
                    "begin": "'",
                    "end": "'"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.omni",
                    "match": "\\b(if|elif|else|for|while|loop|match|break|continue|return|yield|defer|async|await|try|except|finally|raise)\\b"
                },
                {
                    "name": "keyword.declaration.omni",
                    "match": "\\b(fn|struct|enum|trait|impl|type|const|let|var|mut|pub|use|module|import|from|as|in|is|not|and|or)\\b"
                },
                {
                    "name": "keyword.other.omni",
                    "match": "\\b(self|Self|super|crate|own|ref|move|copy|comptime|unsafe|extern|static|inline|where)\\b"
                },
                {
                    "name": "storage.modifier.omni",
                    "match": "\\b(pub|mut|own|ref|static|const|async|unsafe|inline)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.omni",
                    "match": "\\b(bool|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|char|str|String|void|never)\\b"
                },
                {
                    "name": "support.type.builtin.omni",
                    "match": "\\b(Option|Result|Vec|HashMap|HashSet|Map|Set|Box|Rc|Arc|RefCell|Cell|Pin|Future|Stream)\\b"
                },
                {
                    "name": "entity.name.type.omni",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.omni",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                },
                {
                    "name": "entity.name.function.definition.omni",
                    "match": "(?<=fn\\s)([a-z_][a-zA-Z0-9_]*)"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.omni",
                    "match": "\\b(true|false|None|Some|Ok|Err)\\b"
                },
                {
                    "name": "constant.other.caps.omni",
                    "match": "\\b[A-Z][A-Z0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.omni",
                    "match": "(->|=>|::|\\.\\.=?|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|==|!=|<=|>=|&&|\\|\\||\\+|-|\\*|/|%|&|\\||\\^|!|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.omni",
                    "match": "="
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.omni",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*(\\([^)]*\\))?"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.omni",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.omni",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.omni",
                    "match": "\\b0o[0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.omni",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.omni",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        }
    }
}
